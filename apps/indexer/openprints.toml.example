# Copy to: apps/indexer/openprints.toml
# Then run: make cli-index

[database]
# Dev default: use SQLite so designs + identities persist locally.
database_path = "openprints.db"

[indexer]
# Required relay list (one or more ws:// or wss:// URLs):
relays = ["ws://localhost:7447"]

kind = 33301
queue_maxsize = 1000
timeout = 8.0
max_retries = 12
duration = 0.0
log_level = "WARNING"

[api]
# Optional API port for `openprints serve` (default 8080). Env: OPENPRINTS_API_PORT
# api_port = 8080
