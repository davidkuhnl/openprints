# Copy to: apps/indexer/openprints.toml
# Then run: make cli-index

[database]
# Dev default: use SQLite so designs + identities persist locally.
database_path = "openprints.db"

[indexer]
# Required relay list (one or more ws:// or wss:// URLs):
relays = ["ws://localhost:7447"]

# Design indexer (kind 33301). Omit to use defaults.
design_kind = 33301
design_queue_maxsize = 1000
design_timeout = 8.0
design_max_retries = 12
design_duration = 0.0
log_level = "WARNING"

# Identity indexer (kind-0 profile fetch). Omit to use defaults.
# identity_batch_size = 100
# 24 * 60 * 60 = one day
# identity_stale_after_s = 86400
# identity_poll_interval_s = 5.0
# identity_fetch_timeout_s = 6.0

[api]
# Optional API port for `openprints serve` (default 8080). Env: OPENPRINTS_API_PORT
# api_port = 8080
