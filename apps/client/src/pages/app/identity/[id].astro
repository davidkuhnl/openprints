---
import AppLayout from "~/layouts/app-layout.astro";
import IdentityDetailCard from "~/components/identity-detail-card.astro";

export const prerender = false;

const apiBaseUrl = import.meta.env.PUBLIC_OPENPRINTS_API_URL ?? "";
const base = apiBaseUrl ? apiBaseUrl.replace(/\/$/, "") : "";
const { id } = Astro.params;
const identityIdParam: string = typeof id === "string" ? id : "";

const designsPreviewLimit = 6;

let identity: any = null;
let errorTitle: string | null = null;
let errorMessage: string | null = null;
let totalDesignsForIdentity: number | null = null;
let totalVersionsForIdentity: number | null = null;

if (!base) {
  errorTitle = "Identity not available";
  errorMessage =
    "API base URL is not configured. Check PUBLIC_OPENPRINTS_API_URL.";
} else if (!id) {
  errorTitle = "Identity not found";
  errorMessage = "Missing identity id in the URL.";
} else {
  const identityUrl = `${base}/identity/${encodeURIComponent(id)}`;

  try {
    const res = await fetch(identityUrl);

    if (!res.ok) {
      errorTitle = "Identity not found";
      errorMessage = `API responded with ${res.status} ${res.statusText} for this identity.`;
    } else {
      identity = await res.json();
    }
  } catch {
    errorTitle = "Identity not found";
    errorMessage =
      "We couldn't load this identity due to a network or server error.";
  }

  // If identity loaded successfully, fetch scoped design stats for this identity.
  if (!errorMessage && identity) {
    const statsUrl = `${base}/designs/stats?identity_id=${encodeURIComponent(
      id,
    )}`;
    try {
      const statsRes = await fetch(statsUrl);
      if (statsRes.ok) {
        const stats = await statsRes.json();
        totalDesignsForIdentity =
          typeof stats?.designs === "number" ? stats.designs : null;
        totalVersionsForIdentity =
          typeof stats?.versions === "number" ? stats.versions : null;
      } else {
        // Keep null stats on API status errors; page still renders.
      }
    } catch {
      // Keep null stats on network errors; page still renders.
    }
  }
}
---

<AppLayout title="OpenPrints – Identity detail">
  <IdentityDetailCard
    identity={identity}
    errorTitle={errorTitle}
    errorMessage={errorMessage}
    identityId={identityIdParam}
    totalDesignsForIdentity={totalDesignsForIdentity}
    totalVersionsForIdentity={totalVersionsForIdentity}
    designsPreviewLimit={designsPreviewLimit}
  />
</AppLayout>
