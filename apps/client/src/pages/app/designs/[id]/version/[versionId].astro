---
import AppLayout from "~/layouts/app-layout.astro";
import TruncateCopy from "~/components/truncate-copy.astro";
import DesignVersionView from "~/components/design-version-view.astro";
import DesignVersionViewError from "~/components/design-version-view-error.astro";
import { loadDesignVersionViewData } from "~/lib/designs/version-page";

export const prerender = false;

const { id, versionId } = Astro.params;
const data = await loadDesignVersionViewData({
  apiBaseUrl: import.meta.env.PUBLIC_OPENPRINTS_API_URL ?? "",
  designId: id,
  requestedVersionId: versionId,
});
---

<AppLayout title="OpenPrints – Design detail">
  <!-- Keep this so the copy script (CopyValue) is included for TruncateCopy instances below -->
  <TruncateCopy value="" />

  <div class="mx-auto flex max-w-5xl flex-col gap-3">
    <a
      href="/app/designs"
      class="inline-flex w-fit items-center gap-1 text-[10px] text-offset underline-offset-2 hover:underline focus:outline-none focus-visible:outline-none"
    >
      <span>←</span>
      <span>Back to designs</span>
    </a>

    {
      data.kind === "error" ? (
        <DesignVersionViewError
          errorTitle={data.errorTitle}
          errorMessage={data.errorMessage}
          viewContext={data.viewContext}
        />
      ) : (
        <DesignVersionView
          design={data.design}
          versions={data.versions}
          versionsTotal={data.versionsTotal}
          selectedVersion={data.selectedVersion}
          viewContext={data.viewContext}
        />
      )
    }
  </div>
</AppLayout>

<script>
  import { initOwnerEditCtas } from "~/lib/design-owner-edit";

  initOwnerEditCtas();
</script>
