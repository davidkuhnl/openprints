---
import AppLayout from "~/layouts/app-layout.astro";
import TruncateCopy from "~/components/truncate-copy.astro";
import TimestampDisplay from "~/components/timestamp-display.astro";
import IconPill from "~/components/icon-pill.astro";
import IdentityBadge from "~/components/identity-badge.astro";
import Pubkey from "~/components/pubkey.astro";
import MockMarker from "~/components/mock-marker.astro";
import MockDisclaimer from "~/components/mock-disclaimer.astro";
import PreviewMocks from "~/components/preview-mocks.astro";
import { Icon } from "astro-icon/components";

export const prerender = false;

const apiBaseUrl = import.meta.env.PUBLIC_OPENPRINTS_API_URL ?? "";
const base = apiBaseUrl ? apiBaseUrl.replace(/\/$/, "") : "";

const { id } = Astro.params;

let design: any = null;
let errorTitle: string | null = null;
let errorMessage: string | null = null;

if (!base) {
  errorTitle = "Design not available";
  errorMessage =
    "API base URL is not configured. Check PUBLIC_OPENPRINTS_API_URL.";
} else if (!id) {
  errorTitle = "Design not found";
  errorMessage = "Missing design id in the URL.";
} else {
  const url = `${base}/designs/${encodeURIComponent(id)}`;

  try {
    const res = await fetch(url);

    if (!res.ok) {
      errorTitle = "Design not found";
      errorMessage = `API responded with ${res.status} ${res.statusText} for this design.`;
    } else {
      design = await res.json();
    }
  } catch (err: any) {
    errorTitle = "Design not found";
    errorMessage =
      "We couldn't load this design due to a network or server error.";
  }
}

function getTotalZaps(d: any) {
  if (!d) return "–";

  // Prefer aggregating from individual zaps when available
  if (Array.isArray(d.zaps) && d.zaps.length > 0) {
    const total = d.zaps.reduce((sum: number, zap: any) => {
      const amount = getZapAmount(zap);
      return typeof amount === "number" ? sum + amount : sum;
    }, 0);

    if (total > 0) return total;
  }

  if (typeof d.total_zaps === "number") return d.total_zaps;
  if (typeof d.totalZaps === "number") return d.totalZaps;
  return "–";
}

function getEndorsements(d: any) {
  if (!d) return "–";
  // Use endorsements array length when present (real or fake data),
  // otherwise fall back to any pre-computed count from the API.
  if (Array.isArray(d.endorsements)) return d.endorsements.length;
  if (typeof d.endorsements_count === "number") return d.endorsements_count;
  return "–";
}

function getZapAmount(z: any) {
  if (!z) return "–";
  if (typeof z.amount === "number") return z.amount;
  if (typeof z.value === "number") return z.value;
  if (typeof z.sats === "number") return z.sats;
  return "–";
}

const name = design && design.name ? design.name : "Untitled design";

const description =
  design && typeof design.content === "string" ? design.content : "";

const format = design && design.format ? design.format : "–";

const sha256Raw = design && design.sha256 ? design.sha256 : "–";
const sha256MaxChars = 16; // show more of the hash, still truncatable

const firstPublishedAt =
  design && design.first_published_at ? design.first_published_at : null;
const latestPublishedAt =
  design && design.latest_published_at ? design.latest_published_at : null;

const urlValue = design && design.url ? design.url : "";

let previewImages: string[] = [];

if (design && (design as any).tags_json) {
  try {
    const rawTags =
      typeof (design as any).tags_json === "string"
        ? JSON.parse((design as any).tags_json)
        : (design as any).tags_json;

    const previews = rawTags && rawTags.preview;

    if (Array.isArray(previews)) {
      previewImages = previews.filter(
        (item: unknown): item is string =>
          typeof item === "string" && item.trim().length > 0
      );
    }
  } catch {
    // Ignore malformed tags_json
  }
}

// Dev-only fake data to visually test endorsements/zaps layout and meta counts.
// This only runs in development and feeds both the "Top endorsements/zaps"
// lists and the meta pills (total zaps & endorsements count).
if (import.meta.env.DEV && design) {
  if (
    !Array.isArray(design.endorsements) ||
    design.endorsements.length === 0
  ) {
    design.endorsements = [
      {
        pubkey: "npub1endorseraaaa",
        content: "Really solid design, prints cleanly at 0.2mm.",
        created_at: Date.now() - 1000 * 60 * 60 * 2, // 2h ago
      },
      {
        pubkey: "npub1endorserbbbb",
        content: "Used this in a prototype and it held up great.",
        created_at: Date.now() - 1000 * 60 * 60 * 24, // 1 day ago
      },
      {
        pubkey: "npub1endorsercccc",
        content: "Nice balance of material usage and strength.",
        created_at: Date.now() - 1000 * 60 * 60 * 72, // 3 days ago
      },
    ];
  }

  if (!Array.isArray(design.zaps) || design.zaps.length === 0) {
    design.zaps = [
      { pubkey: "npub1zapperaaaa", amount: 500 },
      { pubkey: "npub1zapperbbbb", amount: 250 },
      { pubkey: "npub1zappercccc", amount: 100 },
      { pubkey: "npub1zapperdddd", amount: 50 },
    ];
  }
}

// Totals and counts use real data when present, or dev-only fake data above.
const totalZaps = getTotalZaps(design);
const endorsementsCount = getEndorsements(design);

// Lists for bottom section
const endorsementsList: any[] =
  design && Array.isArray(design.endorsements)
    ? design.endorsements.slice(0, 10)
    : [];

const zapsList: any[] =
  design && Array.isArray(design.zaps) ? design.zaps.slice(0, 10) : [];
---

<AppLayout title="OpenPrints – Design detail">
  <!-- Keep this so the copy script (CopyValue) is included for TruncateCopy instances below -->
  <TruncateCopy value="" />

  <div class="mx-auto flex max-w-5xl flex-col gap-3">
    <a
      href="/app/designs"
      class="inline-flex w-fit items-center gap-1 text-[10px] text-offset underline-offset-2 hover:underline focus:outline-none focus-visible:outline-none"
    >
      <span>←</span>
      <span>Back to designs</span>
    </a>

    <article class="flex flex-col gap-2.5 rounded-xl border border-default bg-offset/30 p-4 sm:p-5">
      {errorMessage && (
        <>
          <h1 class="text-lg font-semibold tracking-tight">
            {errorTitle ?? "Design not found"}
          </h1>
          <p class="mt-1.5 text-xs text-offset">{errorMessage}</p>
          <div class="mt-4">
            <a
              href="/app/designs"
              class="text-[10px] text-offset underline-offset-2 hover:underline"
            >
              ← Back to designs
            </a>
          </div>
        </>
      )}

      {!errorMessage && !design && (
        <>
          <h1 class="text-lg font-semibold tracking-tight">Loading design…</h1>
          <p class="text-xs text-offset">Fetching design details.</p>
        </>
      )}

      {!errorMessage && design && (
        <div>
          <header class="space-y-1.5 border-b border-default pb-4">
            <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-offset">
              Design
            </p>
            <div class="flex flex-wrap items-start justify-between gap-2">
              <h1 class="text-xl font-semibold tracking-tight sm:text-2xl">
                {name}
              </h1>
              {design.pubkey && (
                <span
                  class="hidden shrink-0 rounded-md border border-emerald-400/35 bg-emerald-400/10 px-2.5 py-1 text-[11px] font-semibold text-default"
                  data-owner-edit-cta
                  data-owner-pubkey={design.pubkey}
                  aria-hidden="true"
                  title="Design edit flow is coming in the next phase."
                >
                  Edit design (soon)
                </span>
              )}
            </div>

            <!-- meta pills row -->
            <div class="flex flex-wrap items-center gap-1.5 text-[10px] text-offset">
              <IdentityBadge identity={design.creator_identity} size="full" />

              {firstPublishedAt && (
                <IconPill icon="mdi:calendar-start" title="First published">
                  <TimestampDisplay value={firstPublishedAt} agoFormat />
                </IconPill>
              )}

              {latestPublishedAt && (
                <IconPill icon="mdi:update" title="Latest update">
                  <TimestampDisplay value={latestPublishedAt} agoFormat />
                </IconPill>
              )}

              {format && format !== "–" && (
                <IconPill icon="mdi:file-outline" title="Format">
                  {format}
                </IconPill>
              )}

              {totalZaps !== "–" && (
                <IconPill icon="mdi:lightning-bolt" title="Total zaps">
                  {totalZaps}
                </IconPill>
              )}

              {endorsementsCount !== "–" && (
                <IconPill icon="mdi:heart-outline" title="Endorsements">
                  {endorsementsCount}
                </IconPill>
              )}
            </div>
          </header>

          {description && (
            <div class="mt-2 space-y-3">
              <p class="text-xs leading-relaxed text-offset">
                {description}
              </p>
              {previewImages.length > 0 ? (
                <div class="flex flex-wrap gap-1.5">
                  {previewImages.map((src) => (
                    <img
                      src={src}
                      loading="lazy"
                      alt={`Preview of ${name}`}
                      class="h-24 w-24 shrink-0 rounded-md border border-default/40 bg-default/20 object-cover"
                    />
                  ))}
                </div>
              ) : (
                <PreviewMocks count={5} variant="card" />
              )}
            </div>
          )}

          <!-- File / URL / SHA section -->
          <section class="mt-3 rounded-lg border border-default bg-default/40 p-3 sm:flex sm:items-center sm:justify-between sm:gap-4">
            <div class="min-w-0 text-xs">
              <p class="text-[10px] font-medium uppercase tracking-[0.14em] text-offset">
                File
              </p>

              {urlValue ? (
                <>
                  <p class="mt-1 break-all text-xs text-default">
                    {urlValue}
                  </p>

                {sha256Raw !== "–" && (
                  <div class="mt-1 flex items-center text-[10px] text-offset">
                    {/* label + icon */}
                    <span class="inline-flex items-center gap-1">
                      <Icon
                        name="mdi:identifier"
                        class="size-3"
                        aria-hidden="true"
                      />
                      <span class="uppercase tracking-[0.08em]">
                        SHA-256
                      </span>
                    </span>

                    {/* separator dot */}
                    <span class="mx-1 text-offset/40">•</span>

                    {/* hash value */}
                    <span class="inline-flex items-center font-mono">
                      <TruncateCopy
                        value={sha256Raw}
                        maxChars={sha256MaxChars}
                      />
                    </span>
                  </div>
                )}
                </>
              ) : (
                <p class="mt-1 text-xs text-offset">
                  No file URL available yet for this design.
                </p>
              )}
            </div>

            {urlValue && (
              <div class="mt-3 shrink-0 sm:mt-0">
                <a
                  href={urlValue}
                  class="inline-flex items-center gap-1.5 rounded-md border border-default px-3 py-1.5 text-[11px] font-medium text-default transition-colors hover:text-emerald-400"
                  target="_blank"
                  rel="noreferrer"
                >
                  Download file
                </a>
              </div>
            )}
          </section>

          <!-- Endorsements & Zaps two-column layout -->
          <section class="mt-4 grid gap-4 md:grid-cols-2">
            <!-- Endorsements column -->
            <div class="relative">
                  <MockMarker top={15} right={70} rotation={0} />
              <h2 class="flex items-center gap-1 text-xs font-semibold uppercase tracking-[0.16em] text-offset">
                <Icon
                  name="mdi:heart-outline"
                  class="size-3 shrink-0 text-offset"
                  aria-hidden="true"
                />
                Latest endorsements
              </h2>

              {endorsementsList.length === 0 ? (
                <p class="mt-2 text-xs text-offset">
                  No endorsements yet for this design.
                </p>
              ) : (
                <ul class="mt-2 space-y-2">
                  {endorsementsList.map((endorsement) => (
                    <li class="rounded-lg border border-default border-l-2 border-l-emerald-400 bg-default/40 px-3 py-2.5">
                      <div class="flex items-center justify-between gap-2 text-[10px] text-offset">
                        <Pubkey
                          value={
                            endorsement.pubkey || "Unknown endorser"
                          }
                          maxChars={10}
                        />
                        {endorsement.created_at && (
                          <TimestampDisplay
                            value={endorsement.created_at}
                            agoFormat
                          />
                        )}
                      </div>

                      {endorsement.content && (
                        <p class="mt-1 text-xs leading-snug text-default">
                          {endorsement.content}
                        </p>
                      )}
                    </li>
                  ))}
                </ul>
              )}
            </div>

            <!-- Zaps column -->
            <div class="relative">
              <MockMarker top={15} right={70} rotation={0} />
              <h2 class="flex items-center gap-1 text-xs font-semibold uppercase tracking-[0.16em] text-offset">
                <Icon
                  name="mdi:lightning-bolt"
                  class="size-3 shrink-0"
                  aria-hidden="true"
                />
                Top zaps
              </h2>

              {zapsList.length === 0 ? (
                <p class="mt-2 text-xs text-offset">
                  No zaps yet for this design.
                </p>
              ) : (
                <ul class="mt-2 space-y-2">
                  {zapsList.map((zap) => (
                    <li class="rounded-lg border border-default bg-default/40 px-3 py-2.5">
                      <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-[10px] text-offset">
                          <Pubkey
                            value={zap.pubkey || "Unknown zapper"}
                            maxChars={10}
                          />
                        </span>
                        <span class="text-xs font-medium text-default">
                          {getZapAmount(zap)}
                        </span>
                      </div>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </section>
        </div>
      )}
    </article>

    <MockDisclaimer />
  </div>
</AppLayout>

<script>
  import { initOwnerEditCtas } from "~/lib/design-owner-edit";

  initOwnerEditCtas();
</script>
