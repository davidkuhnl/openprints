---
import AppLayout from "~/layouts/app-layout.astro";
import DesignsList from "~/components/designs-list.astro";
---

<AppLayout title="OpenPrints – All designs">
  <section class="mx-auto flex max-w-5xl flex-col gap-6">
    <header class="space-y-1.5">
      <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-offset">
          Designs
      </p>
      <h1 class="text-xl font-semibold tracking-tight sm:text-2xl">
        All designs
      </h1>
      <p class="max-w-2xl text-xs text-offset">
        A complete list of indexed designs with essential metadata and quick access to details.
      </p>
    </header>
    <DesignsList />
  </section>
</AppLayout>

