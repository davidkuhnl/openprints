---
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
import type { FeatureItem } from "~/types";

const features: Array<FeatureItem> = [
  {
    title: "Open 3D Design Protocol",
    description:
      "Designs are Nostr events, not rows in a private database—portable, verifiable, and owned by your keypair.",
    icon: "mdi:graph",
  },
  {
    title: "Web-of-trust Discovery",
    description:
      "Zaps and Endorsement Nostr events are used to discover and support creators. Your reputation is built on your actions, not the platform.",
    icon: "mdi:star",
  },
  {
    title: "Creator-Owned Monetization",
    description:
      "Lightning zaps flow directly from supporters to creators with no platform custody or payout friction.",
    icon: "mdi:flash",
  },
  {
    title: "Searchable Open Indexer",
    description:
      "A public FastAPI indexer aggregates relay data into a queryable API for lists, search, and detail views.",
    icon: "mdi:database-search",
  },
  {
    title: "Simple or Decentralized Storage",
    description:
      "The designs can be hosted anywhere, S3, you're own server, or a decentralized blob storage service like Blossom. Design gets taken down? Just host it somewhere else and broadcast the update. As long as the hash checks out, the show doesn't stop.",
    icon: "mdi:cloud-sync",
  },
  {
    title: "Censorship-Resistant by Design",
    description:
      "Multiple relays, open-source code, and a protocol-first approach reduce single points of failure or control.",
    icon: "mdi:shield-lock-outline",
  },
];
---

<ContentSection title="Building Blocks" id="buildingblocks" titleClass="text-intro-accent">
  <Fragment slot="lead">
    OpenPrints treats <span class="text-intro-accent">3D designs</span> as open
    protocol data, not siloed marketplace inventory. It combines Nostr, Lightning,
    and simple storage into a <span class="text-intro-accent">creator-owned</span>,
    censorship-resistant foundation for printable models.
  </Fragment>
  <ul class="grid max-w-6xl grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
    {
      features.map(({ title, description, icon }) => (
        <li class="flex flex-col items-center gap-4 border border-intro-accent/30 bg-offset p-6">
          <div class="size-16 rounded-full border-2 border-intro-accent/50 p-3 text-intro-muted">
            <Icon name={icon} class="size-full" />
          </div>
          <p class="text-center font-extrabold text-xl">{title}</p>
          <p class="text-center text-offset text-sm">{description}</p>
        </li>
      ))
    }
  </ul>
</ContentSection>
