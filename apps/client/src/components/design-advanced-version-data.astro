---
import EventJsonPanel from "~/components/event-json-panel.astro";
import TruncateCopy from "~/components/truncate-copy.astro";
import { Icon } from "astro-icon/components";
import { prettyJsonFromString } from "~/lib/json";

type Props = {
  eventId: string | null;
  previousVersionEventId: string | null;
  signedEventJson: string | null;
};

const { eventId, previousVersionEventId, signedEventJson } = Astro.props as Props;

const textareaId = "design-advanced-event-json";
const outputName = "design-advanced-event-json";
const formattedValue = prettyJsonFromString(signedEventJson);

const OPENPRINTS_SCHEMA_TAG = "openprints_schema";
const LEGACY_SCHEMA_VERSION = "1.0";
const UNKNOWN_SCHEMA_VERSION = "unknown";

const resolveSchemaVersion = (rawEventJson: string | null): string => {
  if (!rawEventJson) return LEGACY_SCHEMA_VERSION;

  let parsed: unknown;
  try {
    parsed = JSON.parse(rawEventJson);
  } catch {
    return UNKNOWN_SCHEMA_VERSION;
  }

  if (
    typeof parsed !== "object" ||
    parsed === null ||
    !("tags" in parsed) ||
    !Array.isArray(parsed.tags)
  ) {
    return LEGACY_SCHEMA_VERSION;
  }

  const schemaTags = parsed.tags.filter(
    (tag): tag is string[] =>
      Array.isArray(tag) && typeof tag[0] === "string" && tag[0] === OPENPRINTS_SCHEMA_TAG,
  );
  if (schemaTags.length === 0) return LEGACY_SCHEMA_VERSION;
  if (schemaTags.length !== 1 || typeof schemaTags[0][1] !== "string") return UNKNOWN_SCHEMA_VERSION;

  const value = schemaTags[0][1].trim();
  return value.length > 0 ? value : UNKNOWN_SCHEMA_VERSION;
};

const schemaVersion = resolveSchemaVersion(signedEventJson);
---

<section class="mt-5 border-t border-default/60 pt-4">
  <details class="group">
    <summary
      class="flex w-full cursor-pointer list-none items-start justify-between gap-3 rounded-md px-1 py-1.5 text-left transition-colors hover:bg-default/10 hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
    >
      <div class="min-w-0">
        <p class="text-sm font-medium text-default transition-colors group-hover:text-default/90">
          Technical details
        </p>
        <p class="mt-0.5 text-[11px] leading-relaxed text-offset/75 transition-colors group-hover:text-offset/90">
          View the signed raw event and identifiers for this version.
        </p>
      </div>

      <Icon
        name="mdi:chevron-down"
        class="mt-0.5 size-4 shrink-0 text-offset/80 transition duration-200 group-hover:translate-y-0.5 group-hover:text-default/90 group-open:rotate-180"
        aria-hidden="true"
      />
    </summary>

    <div class="px-1 space-y-4 pt-3">
      <div class=" grid gap-x-8 gap-y-3 sm:grid-cols-2">
        <div class="min-w-0 space-y-1.5">
          <p class="text-[10px] font-medium uppercase tracking-[0.14em] text-offset/70">
            Event ID
          </p>
          {
            eventId ? (
              <div class="min-w-0 text-[13px] leading-5 text-default/85">
                <TruncateCopy value={eventId} maxChars={18} />
              </div>
            ) : (
              <p class="text-[13px] leading-5 text-offset/70">Unavailable</p>
            )
          }
        </div>

        <div class="min-w-0 space-y-1.5">
          <p class="text-[10px] font-medium uppercase tracking-[0.14em] text-offset/70">
            Previous version event ID
          </p>
          {
            previousVersionEventId ? (
              <div class="min-w-0 text-[13px] leading-5 text-default/85">
                <TruncateCopy value={previousVersionEventId} maxChars={18} />
              </div>
            ) : (
              <p class="text-[13px] leading-5 text-offset/70">None (initial version)</p>
            )
          }
        </div>

        <div class="min-w-0 space-y-1.5">
          <p class="text-[10px] font-medium uppercase tracking-[0.14em] text-offset/70">
            Data source
          </p>
          <p class="text-[13px] leading-5 text-default/85">Signed Nostr event</p>
        </div>

        <div class="min-w-0 space-y-1.5">
          <p class="text-[10px] font-medium uppercase tracking-[0.14em] text-offset/70">
            OpenPrints schema
          </p>
          <p class="text-[13px] leading-5 text-default/85">{schemaVersion}</p>
        </div>
      </div>

      {
        formattedValue ? (
          <div class="advanced-json-panel">
            <EventJsonPanel
              sectionTitle=""
              sectionDescription=""
              copyAction="copy-design-advanced-event"
              textareaId={textareaId}
              outputName={outputName}
              headerLabel="Signed event JSON"
              headerValue="signed"
              headerValueClass="text-offset/60"
              value={formattedValue}
            />
          </div>
        ) : (
          <p class="rounded-md border border-default/60 bg-default/10 px-3 py-2 text-[11px] text-offset/75">
            Signed event JSON is unavailable for this version.
          </p>
        )
      }
    </div>
  </details>
</section>

<style is:global>
  #design-advanced-event-json {
    max-height: 14rem;
    overflow: auto;
    font-size: 10px;
    line-height: 1.4;
  }

  .advanced-json-panel > * {
    border-color: color-mix(in srgb, var(--color-border) 65%, transparent) !important;
  }

  .advanced-json-panel textarea {
    background: color-mix(in srgb, var(--color-text) 3.5%, transparent) !important;
  }

  /* Tame the TruncateCopy control specifically inside this metadata row */
  .advanced-json-panel + *,
  details [class*="truncate-copy"] {
    vertical-align: top;
  }
</style>