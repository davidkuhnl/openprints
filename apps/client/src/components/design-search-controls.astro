---
import { Icon } from "astro-icon/components";

interface Props {
  /** Current search query (prefill). */
  q?: string;
  /** Current sort order value. */
  order?: string;
  /** Current page size. */
  limit?: number;
}

const { q = "", order = "latest_published_at_desc", limit = 24 } = Astro.props;

const orderOptions = [
  { value: "latest_published_at_desc", label: "Latest published (newest first)" },
  { value: "latest_published_at_asc", label: "Latest published (oldest first)" },
  { value: "first_published_at_desc", label: "First published (newest first)" },
  { value: "first_published_at_asc", label: "First published (oldest first)" },
] as const;

const limitOptions = [12, 24, 48] as const;

const applyButtonClassBase =
  "inline-flex items-center gap-1 rounded-md border px-3 py-1.5 text-[11px] font-medium transition-colors";
const applyButtonClassEmpty =
  "border-default text-default hover:text-emerald-400";
const applyButtonClassActive =
  "border-emerald-400 bg-emerald-400/10 text-emerald-400 hover:text-emerald-400";
---

<aside class="h-fit rounded-xl border border-default/60 bg-offset/20 p-4">
  <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-offset/80">
    Search controls
  </h2>

  <form method="get" action="/app/designs" class="mt-3 space-y-3">
    <label class="block space-y-1">
      <span class="text-[10px] font-medium uppercase tracking-[0.14em] text-offset/80">
        Query
      </span>
      <input
        id="design-search-q"
        type="search"
        name="q"
        value={q}
        placeholder="Search by design name"
        class="w-full rounded-md border border-default bg-default/40 px-2.5 py-2 text-xs outline-none ring-offset-0 transition focus:border-emerald-400"
      />
    </label>

    <label class="block space-y-1">
      <span class="text-[10px] font-medium uppercase tracking-[0.14em] text-offset/80">
        Sort
      </span>
      <select
        name="order"
        class="w-full rounded-md border border-default bg-default/40 px-2.5 py-2 text-xs outline-none transition focus:border-emerald-400"
      >
        {orderOptions.map((opt) => (
          <option value={opt.value} selected={order === opt.value}>
            {opt.label}
          </option>
        ))}
      </select>
    </label>

    <label class="block space-y-1">
      <span class="text-[10px] font-medium uppercase tracking-[0.14em] text-offset/80">
        Page size
      </span>
      <select
        name="limit"
        class="w-full rounded-md border border-default bg-default/40 px-2.5 py-2 text-xs outline-none transition focus:border-emerald-400"
      >
        {limitOptions.map((n) => (
          <option value={n} selected={limit === n}>{n}</option>
        ))}
      </select>
    </label>

    <div class="flex items-center gap-2 pt-1">
      <button
        id="design-search-apply"
        type="submit"
        class={`${applyButtonClassBase} ${applyButtonClassEmpty}`}
      >
        <Icon name="mdi:magnify" class="size-3.5" aria-hidden="true" />
        Apply
      </button>
      <a
        href="/app/designs"
        class="text-[11px] text-offset underline-offset-2 hover:underline"
      >
        Clear
      </a>
    </div>
  </form>
</aside>

<script define:vars={{ applyButtonClassBase, applyButtonClassEmpty, applyButtonClassActive }}>
  const input = document.getElementById("design-search-q");
  const btn = document.getElementById("design-search-apply");
  if (input && btn) {
    const update = () => {
      const active = input.value.trim() !== "";
      btn.className = `${applyButtonClassBase} ${active ? applyButtonClassActive : applyButtonClassEmpty}`;
    };
    update();
    input.addEventListener("input", update);
  }
</script>
