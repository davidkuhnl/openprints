---
import TruncateCopy from "~/components/truncate-copy.astro";
import { nip19 } from "nostr-tools";

interface Props {
  value: string;
  maxChars?: number;
}

const { value, maxChars = 10 } = Astro.props;

const isHexPubkey = (s: string): boolean => /^[0-9a-f]{64}$/i.test(s);

let displayValue = value;

if (isHexPubkey(value)) {
  try {
    displayValue = nip19.npubEncode(value);
  } catch (err) {
    console.error("Failed to encode pubkey to npub:", err);
  }
}
---

<TruncateCopy value={displayValue} maxChars={maxChars} />