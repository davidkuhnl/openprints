---
import CopyValue from "~/components/copy-value.astro";

interface Props {
  value: string;
  maxChars?: number;
}

const { value, maxChars = 10 } = Astro.props;
// When truncating: first x chars + "…" + last y chars, x + y = maxChars; if odd, x > y
const x = Math.ceil(maxChars / 2);
const y = Math.floor(maxChars / 2);
const display =
  value.length > maxChars
    ? value.slice(0, x) + "…" + value.slice(-y)
    : value;
---

<!-- Visible instance when value is non-empty -->
{value.length > 0 && (
  <span class="truncate-copy inline-flex items-center gap-1">
    <span class="truncate-copy__text">{display}</span>
    <CopyValue value={value} />
  </span>
)}
