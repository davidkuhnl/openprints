---
import { Icon } from "astro-icon/components";
import type { InvalidDesignCard } from "~/lib/designs";
import EventJsonPanel from "~/components/event-json-panel.astro";

interface Props {
  design: InvalidDesignCard;
}

const { design } = Astro.props;

const prettyRaw =
  design.raw_payload != null ? JSON.stringify(design.raw_payload, null, 2) : null;
---

<article class="design-result-card overflow-hidden rounded-xl border border-amber-400/40 bg-offset/20">
  <header class="border-b border-default/50 px-3.5 py-2.5 sm:px-4 sm:py-3">
    <div class="flex items-start gap-3">
      <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-amber-400/30 bg-amber-400/10 text-amber-300/90">
        <Icon name="mdi:alert-outline" class="size-4" aria-hidden="true" />
      </span>

      <div class="min-w-0 flex-1 space-y-1">
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
          <h2 class="text-sm font-semibold tracking-tight text-default">
            Invalid design record
          </h2>
          <span class="inline-flex items-center rounded-full border border-amber-400/25 bg-amber-400/8 px-2 py-0.5 text-[10px] font-medium uppercase tracking-[0.12em] text-amber-300/85">
            Ignored
          </span>
        </div>

        <p class="text-sm leading-relaxed text-offset">
          {design.reason}
        </p>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 pt-0.5 text-[11px] text-offset/75">
          {design.raw_id && (
            <span>
              Received id:{" "}
              <code class="rounded bg-default/20 px-1 py-0.5 font-mono text-[10px] text-default/85">
                {design.raw_id}
              </code>
            </span>
          )}
          <span>This record is excluded from normal design actions.</span>
        </div>
      </div>
    </div>
  </header>

  {prettyRaw && (
    <details class="group px-3.5 py-2.5 sm:px-4 sm:py-3">
      <summary class="inline-flex cursor-pointer list-none items-center gap-1.5 text-[11px] font-medium text-offset/80 transition hover:text-default focus-visible:outline-none">
        <span class="group-open:hidden">More details</span>
        <span class="hidden group-open:inline">Less details</span>
        <Icon
          name="mdi:chevron-down"
          class="size-3.5 transition-transform duration-200 group-open:rotate-180"
          aria-hidden="true"
        />
      </summary>

      <div class="mt-3 space-y-2">
        <div class="space-y-1">
          <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-offset/80">
            Raw payload
          </p>
          <p class="text-[11px] leading-relaxed text-offset/70">
            Original JSON received for this record. Useful for debugging importer or schema issues.
          </p>
        </div>

        <EventJsonPanel
          sectionTitle=""
          sectionDescription=""
          copyAction="copy-invalid-design-json"
          textareaId={`invalid-design-${design.raw_id ?? "unknown"}`}
          outputName="invalid-design-json"
          headerLabel="JSON payload"
          headerValue={design.raw_id ?? "unknown-id"}
          headerValueClass="text-offset/70"
          value={prettyRaw}
        />
      </div>
    </details>
  )}
</article>