---
import { Icon } from "astro-icon/components";
import type { InvalidDesignCard } from "~/lib/designs";
import EventJsonPanel from "~/components/event-json-panel.astro";

interface Props {
  design: InvalidDesignCard;
}

const { design } = Astro.props;

const prettyRaw =
  design.raw_payload != null ? JSON.stringify(design.raw_payload, null, 2) : null;
---

<article class="design-result-card flex flex-col gap-1 rounded-xl border border-amber-400/40 bg-amber-400/10 px-3.5 py-2.5 sm:px-4 sm:py-3">
  <header class="pb-2 mb-2 border-b border-amber-400/25">
    <div class="flex items-center gap-1.5 text-[11px] text-amber-200/90">
      <Icon name="mdi:alert-outline" class="size-3.5 shrink-0" aria-hidden="true" />
      <span class="font-semibold">Malformed / invalid / corrupt design</span>
    </div>
  </header>

  <p class="text-xs text-amber-100/90">{design.reason}</p>

  {design.raw_id && (
    <p class="text-[11px] text-amber-100/70">
      Received design id: <code>{design.raw_id}</code>
    </p>
  )}

  <p class="text-[11px] text-amber-100/70">
    This record is ignored for normal design actions.
  </p>

  {prettyRaw && (
    <div class="mt-2">
      <EventJsonPanel
        sectionTitle="Raw design payload"
        sectionDescription="Original JSON payload received for this design record."
        copyAction="copy-invalid-design-json"
        textareaId={`invalid-design-${design.raw_id ?? "unknown"}`}
        outputName="invalid-design-json"
        headerLabel="JSON payload"
        headerValue={design.raw_id ?? "unknown-id"}
        headerValueClass="text-amber-200/90"
        value={prettyRaw}
      />
    </div>
  )}
</article>

