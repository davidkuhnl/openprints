---
import { Icon } from "astro-icon/components";
import CopyValue from "./copy-value.astro";

const apiBaseUrl = import.meta.env.PUBLIC_OPENPRINTS_API_URL ?? "";
const apiBase = apiBaseUrl ? apiBaseUrl.replace(/\/$/, "") : "";
---

<div
  data-nostr-signer-panel
  data-api-base={apiBase}
  aria-live="polite"
>
  <section
    class="hidden flex flex-col gap-2 border-l-2 border-emerald-400/40 bg-offset/30 p-3 sm:p-4 mb-4"
    data-panel-expanded
  >
    <header class="flex items-start justify-between gap-3">
      <div class="min-w-0 flex-1 space-y-0.5">
        <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-offset">
          Signer detected
        </p>
        <p class="text-sm font-medium text-default" data-panel-title>
          Good news — your Nostr signer is ready.
        </p>
      </div>
    </header>

    <div class="space-y-3 mt-2">
      <!-- Primary identity pills (npub + signed-in location) -->
      <div class="flex flex-wrap items-center gap-2 text-[11px] text-offset/80">
        <span class="inline-flex items-center gap-1 rounded-md border border-default/50 bg-default/10 px-2 py-1">
          <Icon name="mdi:account" class="size-3.5 shrink-0" aria-hidden="true" />
          <span data-panel-identity>—</span>
        </span>
        <span class="inline-flex items-center gap-1 rounded-md border border-default/50 bg-default/10 px-2 py-1">
          <Icon name="mdi:shield-key-outline" class="size-3.5 shrink-0" aria-hidden="true" />
          Signer extension
        </span>
        <span
          class="inline-flex items-center gap-1 rounded-md border border-default/50 bg-default/10 px-2 py-1"
          data-panel-status-pill
        >
          <span class="nostr-dots inline-flex items-center" aria-hidden="true">
            <span class="dot" />
            <span class="dot" />
            <span class="dot" />
          </span>
          Getting pubkey from signer
        </span>
      </div>

      <!-- Identity fetch status text -->
      <div class="space-y-2 mt-3">
        <p class="text-[13px] font-medium text-default" data-panel-message>
          We’re fetching your profile from OpenPrints so we can greet you and show where your designs will be published from.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-2 text-[11px] text-offset/70 hidden mt-3" data-panel-hint-row>
        <p class="text-[12px] text-offset/60" data-panel-hint>
          If this isn't the identity you want, switch accounts in your signer extension and reload.
        </p>
        <button
          type="button"
          class="inline-flex items-center gap-1 text-[11px] text-offset/70 transition hover:text-default"
          data-panel-reload
          onclick="location.reload()"
        >
          <Icon name="mdi:refresh" class="size-4" aria-hidden="true" />
          Reload
        </button>
      </div>
    </div>
  </section>

  <!-- Identity chip: always visible in header, toggles panel -->
  <div
    role="button"
    tabindex="0"
    class="absolute right-4 top-4 inline-flex cursor-pointer items-center gap-1.5 rounded-md border border-emerald-400/30 bg-default/20 px-3 py-1.5 text-[11px] text-offset transition hover:bg-default/30 hover:text-default focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
    data-panel-chip
    aria-label="Toggle signer details"
    aria-expanded="false"
  >
    <span
      class="hidden size-1.5 shrink-0 rounded-full bg-emerald-400 nostr-status-dot"
      data-panel-signed-dot
      aria-hidden="true"
      title="OpenPrints identity confirmed"
    />
    <span data-panel-pill-label>—</span>
    <CopyValue value="Waiting for signer" title="Copy npub" />
    <Icon
      name="mdi:chevron-down"
      class="size-3.5 shrink-0 text-offset/80 transition-transform duration-150"
      data-panel-chevron
      aria-hidden="true"
    />
  </div>
</div>

<style>
  .nostr-dots .dot {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: rgba(52, 211, 153, 0.8);
    display: inline-block;
    margin-right: 4px;
    animation: nostrDot 1.2s infinite ease-in-out;
  }
  .nostr-dots .dot:nth-child(2) { animation-delay: 0.15s; opacity: 0.75; }
  .nostr-dots .dot:nth-child(3) { animation-delay: 0.30s; opacity: 0.55; margin-right: 0; }

  .nostr-status-dot--blinking {
    animation: nostrStatusBlink 1.2s infinite ease-in-out;
  }

  @keyframes nostrDot {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.45; }
    40%           { transform: translateY(-3px); opacity: 1; }
  }

  @keyframes nostrStatusBlink {
    0%, 100% { opacity: 0.35; }
    50%      { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nostr-dots .dot { animation: none !important; }
  }
</style>

<script>
  import { nip19 } from "nostr-tools";

  /** @typedef {{ getPublicKey?: () => Promise<string>; signEvent?: unknown }} NostrSigner */
  /** @typedef {{ display_name_resolved?: string|null; display_name?: string|null; name?: string|null }} IdentityResponse */

  const root = document.querySelector("[data-nostr-signer-panel]");
  if (!root) {
    console.debug("[nostr-signer] no panel root found");
  } else if (root.getAttribute("data-nostr-initialized") === "true") {
    console.debug("[nostr-signer] already initialized on this root, skipping");
  } else {
    root.setAttribute("data-nostr-initialized", "true");
    console.debug("[nostr-signer] panel root found, initializing");
    const apiBase = root.getAttribute("data-api-base") ?? "";

    const titleEl = root.querySelector("[data-panel-title]");
    const msgEl = root.querySelector("[data-panel-message]");
    const pillEl = root.querySelector("[data-panel-status-pill]");
    const expandedPanel = root.querySelector("[data-panel-expanded]");
    const chipEl = root.querySelector("[data-panel-chip]");
    const chevronEl = root.querySelector("[data-panel-chevron]");
    const pillLabelEl = root.querySelector("[data-panel-pill-label]");
    const signedDotEl = root.querySelector("[data-panel-signed-dot]");
    const hintRow = root.querySelector("[data-panel-hint-row]");
    const reloadBtn = root.querySelector("[data-panel-reload]");
    const copyBtn = root.querySelector(".copy-value__btn");

    let hasRendered = false;
    let isRendering = false;
    let isCollapsed = true;
    let fullNpub = "";

    const updatePillLabel = (text) => {
      if (pillLabelEl) pillLabelEl.textContent = text || "—";
    };

    const setCollapsed = (collapsed) => {
      isCollapsed = collapsed;
      if (expandedPanel) expandedPanel.classList.toggle("hidden", collapsed);
      if (chipEl) {
        chipEl.setAttribute("aria-expanded", String(!collapsed));
      }
      if (chevronEl) chevronEl.classList.toggle("rotate-180", !collapsed);
    };

    const setupCollapseToggle = () => {
      chipEl?.addEventListener("click", (e) => {
        const target = /** @type {EventTarget | null} */ (e.target);
        if (target instanceof Element && target.closest(".copy-value__btn")) {
          return;
        }
        setCollapsed(!isCollapsed);
      });
      chipEl?.addEventListener("keydown", (e) => {
        const ev = /** @type {KeyboardEvent} */ (e);
        if (ev.key === "Enter" || ev.key === " ") {
          ev.preventDefault();
          setCollapsed(!isCollapsed);
        }
      });
    };

    const truncateNpub = (npub) => {
      if (!npub || npub.length <= 18) return npub;
      return `${npub.slice(0, 10)}...${npub.slice(-6)}`;
    };

    const setText = (el, text) => {
      if (!el) return;
      el.textContent = text;
    };

    const setPill = (label, mode) => {
      if (!pillEl) return;
      const sharedPillClass =
        "inline-flex items-center gap-1 rounded-md border border-default/50 bg-default/10 px-2 py-1";

      // keep the dots for "checking", remove for other states
      if (mode === "checking") {
        pillEl.className = sharedPillClass;
        pillEl.innerHTML = `
          <span class="nostr-dots inline-flex items-center" aria-hidden="true">
            <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          </span>
          ${label}
        `;
        return;
      }

      const icon =
        mode === "ready"
          ? "✓"
          : mode === "offline"
          ? "!"
          : "";

      pillEl.innerHTML = `<span aria-hidden="true">${icon}</span>${label}`;
      pillEl.className = sharedPillClass;
    };

    const fetchIdentity = async (pubkey) => {
      if (!apiBase) return { identity: null, exists: false, error: "no-api" };

      // TODO: remove this once we have a real API
      const debugPubkey = "a35087a34d787bfc9bf6cdf02aa4c8fb1dbb47db6c2c3c6cd37040d61f857c79"

      const identityUrl = `${apiBase}/identity/${encodeURIComponent(debugPubkey)}`;
      console.debug("[nostr-signer] fetching identity", {
        pubkey,
        url: identityUrl,
      });
      try {
        const res = await fetch(identityUrl, { headers: { accept: "application/json" }});
        if (res.status === 404) return { identity: null, exists: false, error: null };
        if (!res.ok) return { identity: null, exists: false, error: "bad-status" };
        const identity = /** @type {IdentityResponse} */ (await res.json());
        console.debug("[nostr-signer] identity response ok", {
          status: res.status,
          hasIdentity: !!identity,
        });
        return { identity, exists: true, error: null };
      } catch {
        console.warn("[nostr-signer] identity fetch failed");
        return { identity: null, exists: false, error: "network" };
      }
    };

    const renderFromPubkey = async (pubkey) => {
      if (!pubkey) {
        console.debug("[nostr-signer] renderFromPubkey called with empty pubkey");
        return;
      }
      if (hasRendered) {
        console.debug("[nostr-signer] renderFromPubkey skipped (already rendered)");
        return;
      }
      if (isRendering) {
        console.debug("[nostr-signer] renderFromPubkey skipped (render in progress)");
        return;
      }
      isRendering = true;

      console.debug("[nostr-signer] renderFromPubkey start", {
        pubkey,
      });

      try {
        // show npub immediately, so UI feels responsive
        let npub = pubkey;
        try {
          npub = nip19.npubEncode(pubkey);
        } catch {
          console.warn("[nostr-signer] failed to npub-encode pubkey, using raw hex");
        }
        fullNpub = npub;
        const shortNpub = truncateNpub(npub);

        // Fill primary identity pill immediately with truncated npub
        const identityEl = root.querySelector("[data-panel-identity]");
        setText(identityEl, shortNpub);
        updatePillLabel(shortNpub);
        if (copyBtn && fullNpub) {
          copyBtn.setAttribute("data-copy-value", fullNpub);
        }

        if (hintRow instanceof HTMLElement) {
          hintRow.classList.remove("hidden");
        }
        if (reloadBtn instanceof HTMLElement) {
          reloadBtn.classList.remove("hidden");
        }

        if (signedDotEl) {
          signedDotEl.classList.remove("hidden");
          signedDotEl.classList.add("nostr-status-dot--blinking");
        }
        setPill("Checking OpenPrints identity", "checking");

        // Small delay before hitting the API so the
        // \"npub-only\" state is easier to see while debugging.
        await new Promise((resolve) => setTimeout(resolve, 3000));

        const { identity, exists, error } = await fetchIdentity(pubkey);

        if (exists) {
          console.debug("[nostr-signer] identity exists", {
            hasDisplayName: !!identity?.display_name_resolved,
          });
          const displayName = identity?.display_name_resolved;
          if (signedDotEl) {
            signedDotEl.classList.remove("hidden");
            signedDotEl.classList.remove("nostr-status-dot--blinking");
          }
          setPill("OpenPrints identity confirmed", "ready");

          if (displayName) {
            setText(titleEl, `Welcome back, ${displayName}.`);
            setText(
              msgEl,
              "You can now publish designs using this identity."
            );
            setText(identityEl, displayName);
            updatePillLabel(displayName);
          } else {
            setText(titleEl, "Signer ready.");
            updatePillLabel(shortNpub);
            setText(
              msgEl,
              "You can now publish designs using this identity."
            );
          }

          hasRendered = true;
          console.debug("[nostr-signer] renderFromPubkey complete");
          return;
        }

        // identity not in DB yet, or API unavailable
        if (error === "no-api") {
          console.debug("[nostr-signer] no apiBase, skipping identity lookup");
          if (signedDotEl) {
            signedDotEl.classList.add("hidden");
            signedDotEl.classList.remove("nostr-status-dot--blinking");
          }
          setPill("Ready", "ready");
          updatePillLabel(shortNpub);
          setText(titleEl, "Signer ready.");
          setText(
            msgEl,
            "We’ll show your profile once OpenPrints is connected. You can still continue publishing."
          );
        } else if (error) {
          console.warn("[nostr-signer] identity lookup failed", { error });
          if (signedDotEl) {
            signedDotEl.classList.add("hidden");
            signedDotEl.classList.remove("nostr-status-dot--blinking");
          }
          setPill("API unavailable", "offline");
          updatePillLabel(shortNpub);
          setText(titleEl, "Signer ready.");
          setText(
            msgEl,
            "We couldn’t reach the OpenPrints API to look up your profile. You can still continue publishing."
          );
        } else {
          console.debug("[nostr-signer] identity not found, treating as new");
          if (signedDotEl) {
            signedDotEl.classList.add("hidden");
            signedDotEl.classList.remove("nostr-status-dot--blinking");
          }
          setPill("New identity", "ready");
          updatePillLabel(shortNpub);
          setText(titleEl, "Nice to meet you.");
          setText(
            msgEl,
            "We haven’t seen this identity in OpenPrints yet. That’s fine — it will appear once it’s indexed."
          );
        }

        hasRendered = true;
        console.debug("[nostr-signer] renderFromPubkey complete");
      } finally {
        isRendering = false;
      }
    };

    const handleSignerReady = (event) => {
      const customEvent = /** @type {CustomEvent<{ pubkey?: string|null }>} */ (event);
      const pubkey = customEvent?.detail?.pubkey;
      console.debug("[nostr-signer] nostr-signer-ready event", {
        hasPubkey: typeof pubkey === "string" && pubkey.length > 0,
      });
      if (typeof pubkey === "string" && pubkey.length > 0) {
        void renderFromPubkey(pubkey);
      }
    };

    document.addEventListener("nostr-signer-ready", handleSignerReady);
    console.debug("[nostr-signer] listener attached for nostr-signer-ready");

    setupCollapseToggle();
    console.debug("[nostr-signer] collapse toggle wired up");

    const nostr = /** @type {Window & { nostr?: NostrSigner }} */ (window).nostr;
    if (nostr && typeof nostr.getPublicKey === "function" && typeof nostr.signEvent !== "undefined") {
      console.debug("[nostr-signer] window.nostr detected, attempting getPublicKey()");
      nostr
        .getPublicKey()
        .then((pubkey) => {
          console.debug("[nostr-signer] nostr.getPublicKey resolved", {
            hasPubkey: typeof pubkey === "string" && pubkey.length > 0,
          });
          if (typeof pubkey === "string" && pubkey.length > 0) {
            return renderFromPubkey(pubkey);
          }
        })
        .catch((err) => {
          console.warn("[nostr-signer] nostr.getPublicKey failed", err);
          // leave default content
        });
    } else {
      console.debug("[nostr-signer] window.nostr not available or missing methods");
    }
  }
</script>