---
import { Icon } from "astro-icon/components";

const apiBaseUrl = import.meta.env.PUBLIC_OPENPRINTS_API_URL ?? "";
const apiBase = apiBaseUrl ? apiBaseUrl.replace(/\/$/, "") : "";
---

<div
  data-signer-panel
  data-api-base={apiBase}
  aria-live="polite"
>
  <section
    class="animate-identity-in flex flex-col gap-2 bg-offset/30 p-3 sm:p-4"
    data-panel-expanded
  >
    <header class="flex items-start justify-between gap-3">
      <div class="min-w-0 flex-1 space-y-0.5">
        <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-offset">
          Signer detected
        </p>
        <p class="text-sm font-medium text-default" data-panel-title>
          Good news — your Nostr signer is ready.
        </p>
      </div>
    </header>

    <div class="space-y-3 mt-2">
      <div class="flex flex-wrap items-center gap-2 text-[11px] text-offset/80">
        <span class="inline-flex items-center gap-1 rounded-md border border-default/50 bg-default/10 px-2 py-1">
          <Icon name="mdi:account" class="size-3.5 shrink-0" aria-hidden="true" />
          <span data-panel-identity>—</span>
        </span>
        <span class="inline-flex items-center gap-1 rounded-md border border-default/50 bg-default/10 px-2 py-1">
          <Icon name="mdi:shield-key-outline" class="size-3.5 shrink-0" aria-hidden="true" />
          Signer extension
        </span>
        <span
          class="inline-flex items-center gap-1 rounded-md border border-default/50 bg-default/10 px-2 py-1"
          data-panel-status-pill
        >
          <span class="signer-dots inline-flex items-center" data-panel-status-dots aria-hidden="true">
            <span class="dot" />
            <span class="dot" />
            <span class="dot" />
          </span>
          <span class="hidden" data-panel-status-icon aria-hidden="true"></span>
          <span data-panel-status-label>Getting pubkey from signer</span>
        </span>
      </div>

      <div class="space-y-2 mt-3">
        <p class="text-[13px] font-medium text-default" data-panel-message>
          Waiting for your signer to share an identity so we can look it up in OpenPrints.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-2 text-[11px] text-offset/70 hidden mt-3" data-panel-hint-row>
        <p class="text-[12px] text-offset/60" data-panel-hint>
          If this isn't the identity you want, switch accounts in your signer extension and reload.
        </p>
        <button
          type="button"
          class="inline-flex items-center gap-1 text-[11px] text-offset/70 transition hover:text-default"
          data-panel-reload
          onclick="location.reload()"
        >
          <Icon name="mdi:refresh" class="size-4" aria-hidden="true" />
          Reload
        </button>
      </div>
    </div>
  </section>
  <span class="hidden" data-panel-pill-label>—</span>
</div>

<style>
  .animate-identity-in {
    animation: identityIn 180ms ease-out;
  }

  @keyframes identityIn {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .signer-dots .dot {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: rgba(52, 211, 153, 0.8);
    display: inline-block;
    margin-right: 4px;
    animation: signerDot 1.2s infinite ease-in-out;
  }
  .signer-dots .dot:nth-child(2) { animation-delay: 0.15s; opacity: 0.75; }
  .signer-dots .dot:nth-child(3) { animation-delay: 0.30s; opacity: 0.55; margin-right: 0; }

  @keyframes signerDot {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.45; }
    40%           { transform: translateY(-3px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .signer-dots .dot { animation: none !important; }
  }
</style>

<script>
  import {
    startIdentityStore,
    subscribeToCurrentIdentity,
    type IdentitySnapshot,
  } from "~/lib/identity-store";

  type StatusMode = "checking" | "ready" | "offline";

  type SignedDotState = "hidden" | "blinking" | "solid";

  type PanelViewModel = {
    title: string;
    message: string;
    identityText: string;
    chipLabel: string;
    statusLabel: string;
    statusMode: StatusMode;
    signedDot: SignedDotState;
    showHint: boolean;
  };

  type SignerViewChangeDetail = {
    chipLabel: string;
    signedDot: SignedDotState;
  };

  const root = document.querySelector("[data-signer-panel]");
  if (!root || root.getAttribute("data-signer-initialized") === "true") {
    // no-op
  } else {
    root.setAttribute("data-signer-initialized", "true");

    const titleEl = root.querySelector<HTMLElement>("[data-panel-title]");
    const msgEl = root.querySelector<HTMLElement>("[data-panel-message]");
    const pillEl = root.querySelector<HTMLElement>("[data-panel-status-pill]");
    const statusDotsEl = root.querySelector<HTMLElement>("[data-panel-status-dots]");
    const statusIconEl = root.querySelector<HTMLElement>("[data-panel-status-icon]");
    const statusLabelEl = root.querySelector<HTMLElement>("[data-panel-status-label]");
    const pillLabelEl = root.querySelector<HTMLElement>("[data-panel-pill-label]");
    const hintRow = root.querySelector<HTMLElement>("[data-panel-hint-row]");
    const reloadBtn = root.querySelector<HTMLElement>("[data-panel-reload]");

    const updatePillLabel = (text: string) => {
      if (pillLabelEl) pillLabelEl.textContent = text || "—";
    };

    const setText = (el: Element | null, text: string) => {
      if (!el) return;
      el.textContent = text;
    };

    const setPill = (label: string, mode: StatusMode) => {
      if (!pillEl) return;
      const sharedPillClass =
        "inline-flex items-center gap-1 rounded-md border border-default/50 bg-default/10 px-2 py-1";
      pillEl.className = sharedPillClass;

      if (statusLabelEl) statusLabelEl.textContent = label;

      if (mode === "checking") {
        statusDotsEl?.classList.remove("hidden");
        if (statusIconEl) {
          statusIconEl.classList.add("hidden");
          statusIconEl.textContent = "";
        }
        return;
      }

      statusDotsEl?.classList.add("hidden");
      if (statusIconEl) {
        statusIconEl.classList.remove("hidden");
        statusIconEl.textContent = mode === "ready" ? "✓" : "!";
      }
    };

    const applyView = (view: PanelViewModel) => {
      const identityEl = root.querySelector("[data-panel-identity]");
      const rootEl = root as HTMLElement;

      setText(titleEl, view.title);
      setText(msgEl, view.message);
      setText(identityEl, view.identityText);
      setPill(view.statusLabel, view.statusMode);
      updatePillLabel(view.chipLabel);
      rootEl.dataset.signerDotState = view.signedDot;
      document.dispatchEvent(
        new CustomEvent<SignerViewChangeDetail>("openprints-signer-view-change", {
          detail: {
            chipLabel: view.chipLabel,
            signedDot: view.signedDot,
          },
        }),
      );

      if (view.showHint) {
        hintRow?.classList.remove("hidden");
        reloadBtn?.classList.remove("hidden");
      } else {
        hintRow?.classList.add("hidden");
        reloadBtn?.classList.add("hidden");
      }
    };

    const dispatchLnurlMetadata = (
      pubkey: IdentitySnapshot["pubkey"],
      identity: IdentitySnapshot["identity"],
    ) => {
      if (!pubkey) return;
      const lnurl = identity?.lnurl ?? identity?.lud16 ?? identity?.lud06 ?? null;
      document.dispatchEvent(
        new CustomEvent("openprints-identity-metadata", {
          detail: { pubkey, lnurl },
        }),
      );
    };

    const applySnapshot = (snapshot: IdentitySnapshot) => {
      if (!snapshot.pubkey) {
        applyView({
          title: "Signer detected.",
          message:
            "Checking signer pubkey. If your signer is locked, unlock it and keep this page open.",
          identityText: "—",
          chipLabel: "Checking signer",
          statusLabel: "Waiting for signer pubkey",
          statusMode: "checking",
          signedDot: "blinking",
          showHint: true,
        });
        return;
      }

      const signerLabel = snapshot.resolvedDisplayLabel ?? "—";
      if (!snapshot.authoritative) {
        applyView({
          title: "Signer detected.",
          message:
            "Using cached identity as a hint while we confirm the active signer account.",
          identityText: signerLabel,
          chipLabel: signerLabel,
          statusLabel: "Checking signer pubkey",
          statusMode: "checking",
          signedDot: "blinking",
          showHint: true,
        });
        return;
      }

      const identity = snapshot.identity;
      dispatchLnurlMetadata(snapshot.pubkey, identity);
      const identityStatus = (identity?.status ?? "").toLowerCase();
      const identityConfirmed = identityStatus !== "failed";

      if (!identity) {
        applyView({
          title: "Nice to meet you.",
          message:
            "We haven't seen this identity in OpenPrints yet, but you can still use it to sign and publish your design.",
          identityText: signerLabel,
          chipLabel: signerLabel,
          statusLabel: "New identity",
          statusMode: "ready",
          signedDot: "hidden",
          showHint: true,
        });
        return;
      }

      if (!identityConfirmed) {
        applyView({
          title: "Signer ready.",
          message:
            "This identity is known to OpenPrints, but we have not seen its profile on relays yet. You can still continue publishing.",
          identityText: signerLabel,
          chipLabel: signerLabel,
          statusLabel: "Identity not yet seen on relays",
          statusMode: "ready",
          signedDot: "hidden",
          showHint: true,
        });
        return;
      }

      applyView({
        title: `Welcome back, ${signerLabel}.`,
        message: "You're ready to publish with this identity.",
        identityText: signerLabel,
        chipLabel: signerLabel,
        statusLabel: snapshot.refreshing
          ? "Refreshing profile data"
          : "OpenPrints identity confirmed",
        statusMode: "ready",
        signedDot: "solid",
        showHint: true,
      });
    };

    startIdentityStore();
    const unsubscribe = subscribeToCurrentIdentity((snapshot) => {
      applySnapshot(snapshot);
    });

    window.addEventListener(
      "beforeunload",
      () => {
        unsubscribe();
      },
      { once: true },
    );
  }
</script>