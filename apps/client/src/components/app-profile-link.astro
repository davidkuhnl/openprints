---
import { createAvatar } from "@dicebear/core";
import { rings } from "@dicebear/collection";

const apiBaseUrl = import.meta.env.PUBLIC_OPENPRINTS_API_URL ?? "";
const apiBase = apiBaseUrl ? apiBaseUrl.replace(/\/$/, "") : "";

const defaultAvatar = createAvatar(rings, {
  seed: "unknown",
  size: 128,
  radius: 50,
  backgroundColor: ["transparent"],
  ringFive: ["full"],
  ringColor: ["60a5fa", "34d399", "f472b6", "a78bfa", "fb923c"],
});
const defaultFallbackSrc = `data:image/svg+xml;utf8,${encodeURIComponent(defaultAvatar.toString())}`;
---

<a
  href="/app/profile"
  class="inline-flex h-8 w-8 items-center justify-center rounded-full text-offset transition opacity-90 hover:opacity-100 focus-visible:opacity-100 mr-1 sm:mr-1.5"
  aria-label="Open profile"
  title="Profile"
  data-app-profile-link
  data-api-base={apiBase}
  data-default-fallback={defaultFallbackSrc}
  data-loading="false"
  data-booting="true"
  data-timeout="false"
>
  <span class="profile-avatar-shell relative inline-flex h-8 w-8 box-border items-center justify-center border border-default/60 bg-default p-px">
    <span class="profile-avatar-clip relative inline-flex h-full w-full overflow-hidden">
      <img
        src=""
        alt="Your profile avatar"
        loading="eager"
        decoding="async"
        class="profile-avatar-fallback absolute inset-0 block h-full w-full object-cover opacity-0 transition-opacity duration-200 ease-out"
        data-profile-fallback
      />
      <img
        src=""
        alt="Your profile avatar"
        loading="eager"
        decoding="async"
        class="profile-avatar-picture absolute inset-0 block h-full w-full object-cover opacity-0 transition-opacity duration-200 ease-out"
        data-profile-picture
      />
    </span>
  </span>
</a>

<script>
  import {
    buildIdentityShapeMaskDataUri,
    normalizeIdentityShape,
  } from "~/lib/identity-shape";
  import {
    getCurrentIdentity,
    startIdentityStore,
    subscribeToCurrentIdentity,
    type IdentityRecord,
    type IdentitySnapshot,
  } from "~/lib/identity-store";
  import type { Pubkey } from "~/lib/pubkey";
  import { createAvatar } from "@dicebear/core";
  import { rings } from "@dicebear/collection";

  type AvatarMode = "fallback" | "picture";

  const root = document.querySelector<HTMLAnchorElement>("[data-app-profile-link]");
  if (!root || root.dataset.initialized === "true") {
    // no-op
  } else {
    root.dataset.initialized = "true";

    const defaultFallback = root.getAttribute("data-default-fallback") ?? "";
    const shellEl = root.querySelector<HTMLElement>(".profile-avatar-shell");
    const clipEl = root.querySelector<HTMLElement>(".profile-avatar-clip");
    const fallbackEl = root.querySelector<HTMLImageElement>("[data-profile-fallback]");
    const pictureEl = root.querySelector<HTMLImageElement>("[data-profile-picture]");

    let activeRequestId = 0;
    let activePictureUrl = "";
    let activeFallbackSrc = "";
    let activeShape = "";
    let currentMode: AvatarMode | null = null;
    let hasRevealedInitialState = false;

    const setLoading = (isLoading: boolean) => {
      const next = isLoading ? "true" : "false";
      if (root.getAttribute("data-loading") === next) return;
      root.setAttribute("data-loading", next);
    };

    const setBooting = (isBooting: boolean) => {
      const next = isBooting ? "true" : "false";
      if (root.getAttribute("data-booting") === next) return;
      root.setAttribute("data-booting", next);
    };

    const revealOnce = () => {
      if (hasRevealedInitialState) return;
      hasRevealedInitialState = true;
      setBooting(false);
    };

    const fallbackAvatarSrc = (seed: string): string => {
      const avatar = createAvatar(rings, {
        seed: seed || "unknown",
        size: 128,
        radius: 50,
        backgroundColor: ["transparent"],
        ringFive: ["full"],
        ringColor: ["60a5fa", "34d399", "f472b6", "a78bfa", "fb923c"],
      });
      return `data:image/svg+xml;utf8,${encodeURIComponent(avatar.toString())}`;
    };

    const clearShapeMask = () => {
      if (shellEl) {
        shellEl.style.removeProperty("-webkit-mask-image");
        shellEl.style.removeProperty("mask-image");
        shellEl.style.removeProperty("-webkit-mask-size");
        shellEl.style.removeProperty("mask-size");
        shellEl.style.removeProperty("-webkit-mask-repeat");
        shellEl.style.removeProperty("mask-repeat");
        shellEl.style.removeProperty("-webkit-mask-position");
        shellEl.style.removeProperty("mask-position");
        shellEl.style.removeProperty("-webkit-mask-mode");
        shellEl.style.removeProperty("mask-mode");
      }
      if (clipEl) {
        clipEl.style.removeProperty("-webkit-mask-image");
        clipEl.style.removeProperty("mask-image");
        clipEl.style.removeProperty("-webkit-mask-size");
        clipEl.style.removeProperty("mask-size");
        clipEl.style.removeProperty("-webkit-mask-repeat");
        clipEl.style.removeProperty("mask-repeat");
        clipEl.style.removeProperty("-webkit-mask-position");
        clipEl.style.removeProperty("mask-position");
        clipEl.style.removeProperty("-webkit-mask-mode");
        clipEl.style.removeProperty("mask-mode");
      }
    };

    const applyShape = (shapeRaw: string | null | undefined) => {
      const normalized = normalizeIdentityShape(shapeRaw);
      const nextShape = normalized ?? "";
      if (activeShape === nextShape) return;
      activeShape = nextShape;

      if (!normalized) {
        root.setAttribute("data-shape-mode", "circle");
        root.removeAttribute("data-shape-emoji");
        clearShapeMask();
        return;
      }

      const maskSrc = buildIdentityShapeMaskDataUri(normalized);
      if (!maskSrc) {
        root.setAttribute("data-shape-mode", "circle");
        root.removeAttribute("data-shape-emoji");
        clearShapeMask();
        return;
      }
      const maskValue = `url("${maskSrc}")`;
      root.setAttribute("data-shape-mode", "emoji");
      root.setAttribute("data-shape-emoji", normalized);

      for (const element of [shellEl, clipEl]) {
        if (!element) continue;
        element.style.setProperty("-webkit-mask-image", maskValue);
        element.style.setProperty("mask-image", maskValue);
        element.style.setProperty("-webkit-mask-size", "contain");
        element.style.setProperty("mask-size", "contain");
        element.style.setProperty("-webkit-mask-repeat", "no-repeat");
        element.style.setProperty("mask-repeat", "no-repeat");
        element.style.setProperty("-webkit-mask-position", "center");
        element.style.setProperty("mask-position", "center");
        element.style.setProperty("-webkit-mask-mode", "alpha");
        element.style.setProperty("mask-mode", "alpha");
      }
    };

    const ensureFallbackSrc = (src: string) => {
      if (!fallbackEl) return;
      if (activeFallbackSrc === src && fallbackEl.src === src) return;
      activeFallbackSrc = src;
      fallbackEl.src = src;
    };

    const transitionToMode = (mode: AvatarMode) => {
      if (!fallbackEl || !pictureEl) return;
      if (currentMode === mode && hasRevealedInitialState) return;

      if (mode === "fallback") {
        fallbackEl.classList.remove("opacity-0");
        fallbackEl.classList.add("opacity-100");
        pictureEl.classList.remove("opacity-100");
        pictureEl.classList.add("opacity-0");
      } else {
        pictureEl.classList.remove("opacity-0");
        pictureEl.classList.add("opacity-100");
        fallbackEl.classList.remove("opacity-100");
        fallbackEl.classList.add("opacity-0");
      }

      currentMode = mode;
      revealOnce();
    };

    const showFallbackWithSeed = (seed: string) => {
      ensureFallbackSrc(seed ? fallbackAvatarSrc(seed) : defaultFallback);
      activePictureUrl = "";
      if (pictureEl && pictureEl.src) {
        pictureEl.src = "";
      }
      transitionToMode("fallback");
      setLoading(false);
    };

    const preloadImage = (url: string): Promise<void> =>
      new Promise((resolve, reject) => {
        const img = new Image();
        img.decoding = "async";
        img.onload = () => resolve();
        img.onerror = () => reject(new Error("image preload failed"));
        img.src = url;
      });

    const showPicture = async (
      pictureUrl: string,
      requestId: number,
      fallbackSeed: string,
      keepPulsing: boolean,
    ) => {
      if (!pictureEl) return;

      try {
        await preloadImage(pictureUrl);
        if (requestId !== activeRequestId) return;
        if (activePictureUrl !== pictureUrl) {
          activePictureUrl = pictureUrl;
          pictureEl.src = pictureUrl;
        }
        ensureFallbackSrc(fallbackSeed ? fallbackAvatarSrc(fallbackSeed) : defaultFallback);
        transitionToMode("picture");
        setLoading(keepPulsing);
      } catch {
        if (requestId !== activeRequestId) return;
        showFallbackWithSeed(fallbackSeed);
        setLoading(keepPulsing);
      }
    };

    const showPictureImmediateIfAlreadyActive = (
      pictureUrl: string,
      fallbackSeed: string,
      keepPulsing: boolean,
    ) => {
      if (!pictureEl) return false;
      if (activePictureUrl !== pictureUrl || !pictureEl.src) return false;
      ensureFallbackSrc(fallbackSeed ? fallbackAvatarSrc(fallbackSeed) : defaultFallback);
      transitionToMode("picture");
      setLoading(keepPulsing);
      return true;
    };

    const applyIdentity = (
      pubkey: Pubkey | null,
      identity: IdentityRecord | null,
      authoritative: boolean,
      signerStatus: IdentitySnapshot["signerStatus"],
    ) => {
      if (!pubkey) {
        root.href = "/app/profile";
        root.title = "Profile";
        root.setAttribute("aria-label", "Open profile");
        return;
      }

      root.href = `/app/profile?id=${encodeURIComponent(pubkey)}`;
      const displayName =
        identity?.display_name_resolved ||
        identity?.display_name ||
        identity?.name ||
        "Profile";
      if (authoritative) {
        root.title = displayName;
      } else if (signerStatus === "timed_out") {
        root.title = `${displayName} (signer timeout - click to open profile)`;
      } else {
        root.title = `${displayName} (checking signer)`;
      }
      root.setAttribute(
        "aria-label",
        authoritative
          ? `Open profile (${displayName})`
          : signerStatus === "timed_out"
            ? `Open profile (${displayName}, signer timeout)`
            : `Open profile (${displayName}, checking signer)`,
      );
    };

    const applySnapshot = (snapshot: IdentitySnapshot, requestId: number) => {
      applyIdentity(
        snapshot.pubkey,
        snapshot.identity,
        snapshot.authoritative,
        snapshot.signerStatus,
      );
      const isProvisional = Boolean(snapshot.pubkey) && !snapshot.authoritative;
      const shouldPulse =
        snapshot.refreshing ||
        (isProvisional && snapshot.signerStatus === "checking");
      const showTimeoutHalo = isProvisional && snapshot.signerStatus === "timed_out";
      root.setAttribute("data-timeout", showTimeoutHalo ? "true" : "false");

      if (!snapshot.pubkey) {
        applyShape(null);
        showFallbackWithSeed("");
        setLoading(false);
        revealOnce();
        return;
      }

      applyShape(snapshot.identity?.shape ?? null);

      const picture = snapshot.identity?.picture?.trim();
      if (picture) {
        if (!showPictureImmediateIfAlreadyActive(picture, snapshot.pubkey, shouldPulse)) {
          void showPicture(picture, requestId, snapshot.pubkey, shouldPulse);
        } else {
          setLoading(shouldPulse);
          revealOnce();
        }
      } else {
        showFallbackWithSeed(snapshot.pubkey);
        setLoading(shouldPulse);
        revealOnce();
      }
    };

    setLoading(true);
    startIdentityStore();
    void getCurrentIdentity({ allowCache: true });

    const unsubscribe = subscribeToCurrentIdentity((snapshot) => {
      activeRequestId += 1;
      applySnapshot(snapshot, activeRequestId);
    });

    window.addEventListener(
      "beforeunload",
      () => {
        unsubscribe();
      },
      { once: true },
    );
  }
</script>

<style>
  [data-app-profile-link][data-booting="true"] .profile-avatar-shell {
    visibility: hidden;
    opacity: 0;
  }

  [data-app-profile-link][data-booting="false"] .profile-avatar-shell {
    visibility: visible;
    opacity: 1;
  }

  .profile-avatar-shell {
    transform-origin: center;
    transition: opacity 140ms ease;
    border-radius: 9999px;
  }

  .profile-avatar-clip {
    border-radius: 9999px;
  }

  @supports ((-webkit-mask-image: url("")) or (mask-image: url(""))) {
    [data-app-profile-link][data-shape-mode="emoji"] .profile-avatar-shell,
    [data-app-profile-link][data-shape-mode="emoji"] .profile-avatar-clip {
      border-radius: 0;
    }
  }

  .profile-avatar-shell::after {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 9999px;
    box-shadow: 0 0 0 0 rgba(52, 211, 153, 0);
    opacity: 0;
    pointer-events: none;
    animation: profileAvatarPulseHalo 1.6s ease-in-out infinite;
    transition: opacity 220ms ease-out;
  }

  [data-app-profile-link][data-loading="true"] .profile-avatar-shell::after {
    opacity: 1;
  }

  [data-app-profile-link][data-timeout="true"] .profile-avatar-shell::after {
    opacity: 1;
    animation: none;
    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.42);
  }

  @keyframes profileAvatarPulseHalo {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(52, 211, 153, 0);
    }
    50% {
      box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.18);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-app-profile-link][data-loading="true"] .profile-avatar-shell::after,
    .profile-avatar-fallback,
    .profile-avatar-picture,
    .profile-avatar-shell,
    .profile-avatar-shell::after {
      animation: none;
      transition: none;
    }
  }
</style>