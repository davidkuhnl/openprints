---
import RecentDesignsGrid from "~/components/recent-designs-grid.astro";
---

<section
  id="recent-designs"
  class="flex scroll-mt-24 flex-col items-center gap-4 space-y-8"
>
  <div class="flex flex-col items-center gap-4">
    <h2 class="text-center font-extrabold tracking-tight text-6xl text-intro-accent">
      Recent Designs
    </h2>
  </div>
  <p class="max-w-xl text-center font-extrabold text-2xl">
    A quick peek at what’s live in the indexer.
  </p>
  <div class="max-w-6xl w-full">
    <RecentDesignsGrid limit={6} />
    <div class="mt-6 text-center">
      <a
        href="/app"
        class="inline-flex items-center justify-center gap-2 border border-intro-accent px-4 py-2 text-sm font-semibold text-intro-accent transition hover:bg-offset"
      >
        Open app
      </a>
    </div>
  </div>
</section>

