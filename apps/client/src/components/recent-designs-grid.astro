---
// apps/client/src/components/recent-designs-grid.astro
import DesignResultCard from "~/components/design-result-card.astro";
import {
  mapUnknownDesignListToCardModels,
  type DesignCardModel,
} from "~/lib/designs";

const apiBaseUrl = import.meta.env.PUBLIC_OPENPRINTS_API_URL ?? "";
const {
  limit = 6,
  items: providedItems = null,
  errorMessage: providedErrorMessage = null,
  emptyMessage = "No designs yet.",
  identityId = null,
  emptyActionHref = null,
  emptyActionLabel = null,
} = Astro.props;

const base = apiBaseUrl ? apiBaseUrl.replace(/\/$/, "") : "";

let items: DesignCardModel[] = mapUnknownDesignListToCardModels(providedItems);
let errorMessage: string | null =
  typeof providedErrorMessage === "string" ? providedErrorMessage : null;

if (!Array.isArray(providedItems)) {
  if (!base) {
    errorMessage =
      "API base URL is not configured. Check PUBLIC_OPENPRINTS_API_URL.";
  } else {
    const params = new URLSearchParams({
      limit: String(limit),
      order: "latest_published_at_desc",
    });

    if (identityId) {
      params.set("identity_id", identityId);
    }

    const url = `${base}/designs?${params.toString()}`;
    try {
      const res = await fetch(url);
      if (!res.ok) {
        errorMessage = `Failed to load designs (${res.status} ${res.statusText}).`;
      } else {
        const data = await res.json();
        items = mapUnknownDesignListToCardModels(data?.items);
      }
    } catch {
      errorMessage =
        "We couldn't load recent designs due to a network or server error.";
    }
  }
}
---

<section class="recent-designs-grid grid gap-3 md:grid-cols-2 lg:grid-cols-3">
  {errorMessage && (
    <article class="col-span-full rounded-xl border border-default bg-offset/30 p-4 text-center">
      <p class="text-xs text-offset">{errorMessage}</p>
    </article>
  )}

  {!errorMessage && items.length === 0 && (
    <article class="col-span-full rounded-xl border border-default bg-offset/30 p-4 text-center">
      <p class="text-xs text-offset">{emptyMessage}</p>
      {typeof emptyActionHref === "string" &&
        emptyActionHref.length > 0 &&
        typeof emptyActionLabel === "string" &&
        emptyActionLabel.length > 0 && (
          <div class="mt-3">
            <a
              href={emptyActionHref}
              class="inline-flex items-center gap-1.5 rounded-md border border-emerald-400/40 bg-emerald-400/10 px-3 py-1.5 text-[11px] font-medium text-default transition hover:bg-emerald-400/20 hover:text-emerald-400"
            >
              {emptyActionLabel}
              <span aria-hidden="true">→</span>
            </a>
          </div>
        )}
    </article>
  )}

  {!errorMessage &&
    items.length > 0 &&
    items.map((design) => (
      <DesignResultCard design={design} />
    ))}
</section>