---
import { Icon } from "astro-icon/components";
import NostrSignerDetected from "~/components/nostr-signer-detected.astro";
import DesignPublishStepPanel from "~/components/design-publish-step-panel.astro";

const apiBaseUrl = import.meta.env.PUBLIC_OPENPRINTS_API_URL ?? "";
const apiBase = apiBaseUrl ? apiBaseUrl.replace(/\/$/, "") : "";
---

<section
  class="space-y-3 px-4 pb-4 pt-3 sm:px-5 sm:pb-5 sm:pt-4"
  data-design-publish-form
  data-api-base={apiBase}
  aria-live="polite"
>
  <p class="px-1 text-[11px] text-offset/85">Complete one step at a time. Each step unlocks the next.</p>

  <form class="space-y-0" data-publish-form novalidate>
    <DesignPublishStepPanel
      stepId="signer"
      stepNumber={1}
      title="Signer"
      summary="Signer"
      showBack={false}
      panelClass="bg-transparent"
    >
      <Fragment slot="value">
        <span
          class="hidden items-center gap-1.5 whitespace-nowrap rounded-md border border-emerald-400/20 bg-emerald-400/6 px-2.5 py-1 text-[11px] text-offset/90 sm:inline-flex"
          data-step-signer-pill
        >
          <span class="hidden size-1.5 shrink-0 rounded-full bg-emerald-400" data-step-signer-dot aria-hidden="true" />
          <span data-step-signer-pill-text>-</span>
        </span>
      </Fragment>
      <div class="relative">
        <NostrSignerDetected />
      </div>
    </DesignPublishStepPanel>

    <DesignPublishStepPanel stepId="name" stepNumber={2} title="Name" summary="Add a clear design name">
      <div class="space-y-1.5">
        <label for="design-name" class="text-xs font-medium text-default">Name <span class="text-red-400">*</span></label>
        <input id="design-name" name="name" type="text" maxlength="140" required autocomplete="off" placeholder="Phone Stand" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="name" />
        <p class="text-[11px] text-offset">1-120 chars after normalization and trim.</p>
      </div>
    </DesignPublishStepPanel>

    <DesignPublishStepPanel stepId="format" stepNumber={3} title="Format and MIME type" summary="Choose the primary format">
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="space-y-1.5">
          <label for="design-format" class="text-xs font-medium text-default">Format <span class="text-red-400">*</span></label>
          <select id="design-format" name="format" required class="w-full rounded-md border border-default bg-offset/10 px-3 py-2 text-xs text-default focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="format">
            <option value="">Select a format...</option>
            <option value="stl">stl</option>
            <option value="3mf">3mf</option>
            <option value="step">step</option>
            <option value="obj">obj</option>
            <option value="gcode">gcode</option>
          </select>
        </div>
        <div class="space-y-1.5">
          <label for="design-mime" class="text-xs font-medium text-default">MIME type <span class="text-offset/70">(optional)</span></label>
          <input id="design-mime" name="m" type="text" autocomplete="off" placeholder="model/stl" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="mime" />
        </div>
      </div>
    </DesignPublishStepPanel>

    <DesignPublishStepPanel stepId="file" stepNumber={4} title="File URL and SHA-256" summary="Add a file URL and optional digest">
      <div class="space-y-3">
        <div class="space-y-1.5">
          <label for="design-url" class="text-xs font-medium text-default">File URL <span class="text-red-400">*</span></label>
          <input id="design-url" name="url" type="url" required autocomplete="off" placeholder="https://example.com/designs/phone-stand.stl" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="url" />
        </div>
        <div class="space-y-1.5">
          <label for="design-sha256" class="text-xs font-medium text-default">SHA-256 <span class="text-offset/70">(optional in V1)</span></label>
          <input id="design-sha256" name="sha256" type="text" autocomplete="off" placeholder="64-char lowercase hex digest" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs font-mono text-default placeholder:font-sans placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="sha256" />
        </div>
      </div>
    </DesignPublishStepPanel>

    <DesignPublishStepPanel stepId="description" stepNumber={5} title="Description" summary="Optional description">
      <div class="space-y-1.5">
        <label for="design-description" class="text-xs font-medium text-default">Description <span class="text-offset/70">(optional)</span></label>
        <textarea id="design-description" name="description" rows="4" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" placeholder="Short description. Markdown allowed." data-field="description"></textarea>
      </div>
    </DesignPublishStepPanel>

    <DesignPublishStepPanel stepId="advanced" stepNumber={6} title="Advanced" summary="Optional metadata" showNext={false}>
      <div class="space-y-3">
        <div class="space-y-1.5">
          <label for="design-license" class="text-xs font-medium text-default">License <span class="text-offset/70">(optional)</span></label>
          <input id="design-license" name="license" type="text" autocomplete="off" placeholder="CC-BY-4.0" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="license" />
        </div>
        <div class="space-y-1.5">
          <label for="design-preview" class="text-xs font-medium text-default">Preview image URLs (one per line)</label>
          <textarea id="design-preview" name="preview" rows="3" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" placeholder="https://.../preview.png" data-field="preview"></textarea>
        </div>
        <div class="space-y-1.5">
          <label for="design-category" class="text-xs font-medium text-default">Categories (one per line)</label>
          <textarea id="design-category" name="category" rows="3" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" placeholder="holder" data-field="category"></textarea>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <div class="space-y-1.5">
            <label for="design-material" class="text-xs font-medium text-default">Materials tested (one per line)</label>
            <textarea id="design-material" name="material" rows="3" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" placeholder="PLA" data-field="material"></textarea>
          </div>
          <div class="space-y-1.5">
            <label for="design-printer" class="text-xs font-medium text-default">Printers tested (one per line)</label>
            <textarea id="design-printer" name="printer" rows="3" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" placeholder="Prusa MK4" data-field="printer"></textarea>
          </div>
        </div>
        <div class="space-y-1.5">
          <label for="design-lnurl" class="text-xs font-medium text-default">LNURL pay address <span class="text-offset/70">(optional)</span></label>
          <input id="design-lnurl" name="lnurl" type="text" autocomplete="off" placeholder="lnurlp://creator.example.com/pay" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="lnurl" />
          <input type="hidden" name="d" data-field="d" />
        </div>
      </div>
    </DesignPublishStepPanel>

    <div class="mt-3 space-y-3 border-t border-default/60 px-3 pt-3">
      <div class="flex flex-wrap items-center gap-2">
        <button type="button" class="inline-flex items-center gap-2 rounded-md border border-emerald-400/40 bg-emerald-400/10 px-3 py-2 text-xs font-medium text-default transition hover:bg-emerald-400/20 disabled:cursor-not-allowed disabled:opacity-45 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-action="sign">
          <Icon name="mdi:pen" class="size-4" />
          Sign design event
        </button>
        <button type="button" class="inline-flex items-center gap-2 rounded-md border border-sky-400/40 bg-sky-400/10 px-3 py-2 text-xs font-medium text-default transition hover:bg-sky-400/20 disabled:cursor-not-allowed disabled:opacity-45 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300/60" data-action="publish" disabled>
          <Icon name="mdi:send" class="size-4" />
          Publish to network
        </button>
        <button type="button" class="inline-flex items-center gap-2 rounded-md border border-default px-3 py-2 text-xs text-offset transition hover:bg-default/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-action="reset">
          <Icon name="mdi:refresh" class="size-4" />
          Reset
        </button>
        <button type="button" class="inline-flex items-center gap-2 rounded-md border border-default px-3 py-2 text-xs text-offset transition hover:bg-default/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-action="copy-signed" disabled>
          <Icon name="mdi:content-copy" class="size-4" />
          Copy signed JSON
        </button>
        <button type="button" class="inline-flex items-center gap-1.5 rounded-md border border-default px-2.5 py-1.5 text-[11px] font-medium text-offset transition hover:bg-default/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-action="toggle-hacker" aria-expanded="false">
          <Icon name="mdi:code-tags" class="size-4" />
          <span data-hacker-toggle-label>Show advanced</span>
        </button>
      </div>
      <p class="text-xs text-offset" data-sign-status>Waiting for signer pubkey...</p>
      <div class="hidden space-y-3" data-hacker-field>
        <div class="space-y-1.5">
          <label for="unsigned-event" class="text-xs font-medium text-default">Unsigned event preview</label>
          <textarea id="unsigned-event" rows="10" readonly class="w-full rounded-md border border-default bg-black/15 px-3 py-2 font-mono text-[11px] text-default" data-output="unsigned"></textarea>
        </div>
        <div class="space-y-1.5">
          <div class="flex items-center justify-between gap-2">
            <label for="signed-event" class="text-xs font-medium text-default">Signed event payload</label>
            <button type="button" class="inline-flex items-center gap-1.5 rounded-md border border-default px-2.5 py-1.5 text-[11px] text-offset transition hover:bg-default/30 disabled:cursor-not-allowed disabled:opacity-45" data-action="copy-signed-advanced" disabled>
              <Icon name="mdi:content-copy" class="size-4" />
              Copy
            </button>
          </div>
          <textarea id="signed-event" rows="10" readonly class="w-full rounded-md border border-default bg-black/15 px-3 py-2 font-mono text-[11px] text-default" data-output="signed"></textarea>
        </div>
        <p class="text-[11px] text-offset" data-validation-summary>Waiting for signer and valid inputs.</p>
      </div>
    </div>
  </form>
</section>

<script>
  type NostrTag = [string, string];
  type StepId =
    | "signer"
    | "name"
    | "format"
    | "file"
    | "description"
    | "advanced";

  type UnsignedNostrEvent = {
    kind: number;
    created_at: number;
    pubkey: string;
    tags: NostrTag[];
    content: string;
  };

  type SignedNostrEvent = UnsignedNostrEvent & {
    id: string;
    sig: string;
  };

  type PublishRelayResult = {
    relay: string;
    event_id: string;
    accepted: boolean;
    duplicate?: boolean;
    message: string;
  };

  type PublishResponse = {
    ok: boolean;
    event_id?: string;
    relay_results?: PublishRelayResult[];
    accepted_relay_count?: number;
    duplicate_relay_count?: number;
    rejected_relay_count?: number;
    errors?: Array<{ message?: string }>;
  };

  type NostrSigner = {
    signEvent: (event: UnsignedNostrEvent) => Promise<SignedNostrEvent>;
  };

  type SharedSignerState = {
    pubkey?: string | null;
    signerAvailable?: boolean;
    lnurl?: string | null;
  };

  type BuildResult =
    | { ok: true; event: UnsignedNostrEvent; warnings: string[] }
    | { ok: false; errors: string[] };

  type Inputs = {
    d: string;
    name: string;
    format: string;
    url: string;
    sha256: string;
    description: string;
    preview: string;
    category: string;
    material: string;
    printer: string;
    license: string;
    lnurl: string;
    mime: string;
  };

  type FieldName = keyof Inputs;

  type IdentityMetadataDetail = {
    pubkey?: string | null;
    lnurl?: string | null;
  };

  type SignerViewChangeDetail = {
    chipLabel?: string;
    signedDot?: "hidden" | "blinking" | "solid";
  };

  const root = document.querySelector<HTMLElement>("[data-design-publish-form]");
  if (!root || root.dataset.initialized === "true") {
    // no-op
  } else {
    root.dataset.initialized = "true";

    const form = root.querySelector<HTMLFormElement>("[data-publish-form]");
    const signButton = root.querySelector<HTMLButtonElement>("[data-action='sign']");
    const publishButton = root.querySelector<HTMLButtonElement>("[data-action='publish']");
    const resetButton = root.querySelector<HTMLButtonElement>("[data-action='reset']");
    const signStatus = root.querySelector<HTMLElement>("[data-sign-status]");
    const validationSummary = root.querySelector<HTMLElement>("[data-validation-summary]");
    const unsignedOutput = root.querySelector<HTMLTextAreaElement>("[data-output='unsigned']");
    const signedOutput = root.querySelector<HTMLTextAreaElement>("[data-output='signed']");
    const hackerToggleButton = root.querySelector<HTMLButtonElement>("[data-action='toggle-hacker']");
    const hackerToggleLabel = root.querySelector<HTMLElement>("[data-hacker-toggle-label]");
    const hackerFields = Array.from(root.querySelectorAll<HTMLElement>("[data-hacker-field]"));
    const signerPill = root.querySelector<HTMLElement>("[data-step-signer-pill]");
    const signerPillText = root.querySelector<HTMLElement>("[data-step-signer-pill-text]");
    const signerPillDot = root.querySelector<HTMLElement>("[data-step-signer-dot]");
    const signerPanelHost = root.querySelector<HTMLElement>("[data-nostr-signer-panel]");

    const copySignedBtn = root.querySelector<HTMLButtonElement>("[data-action='copy-signed']");
    const copySignedBtnAdv = root.querySelector<HTMLButtonElement>("[data-action='copy-signed-advanced']");

    if (
      !form ||
      !signButton ||
      !publishButton ||
      !resetButton ||
      !signStatus ||
      !unsignedOutput ||
      !signedOutput ||
      !hackerToggleButton ||
      !hackerToggleLabel ||
      hackerFields.length === 0 ||
      !signerPillText ||
      !signerPillDot ||
      !copySignedBtn ||
      !copySignedBtnAdv
    ) {
      console.error("[design-publish-form] required DOM node missing");
    } else {
      const getInput = <T extends HTMLElement>(field: FieldName): T => {
        const node = root.querySelector<T>(`[data-field='${field}']`);
        if (!node) throw new Error(`Missing field node: ${field}`);
        return node;
      };

      const fields = {
        d: getInput<HTMLInputElement>("d"),
        name: getInput<HTMLInputElement>("name"),
        format: getInput<HTMLSelectElement>("format") as unknown as HTMLInputElement,
        url: getInput<HTMLInputElement>("url"),
        sha256: getInput<HTMLInputElement>("sha256"),
        description: getInput<HTMLTextAreaElement>("description"),
        preview: getInput<HTMLTextAreaElement>("preview"),
        category: getInput<HTMLTextAreaElement>("category"),
        material: getInput<HTMLTextAreaElement>("material"),
        printer: getInput<HTMLTextAreaElement>("printer"),
        license: getInput<HTMLInputElement>("license"),
        lnurl: getInput<HTMLInputElement>("lnurl"),
        mime: getInput<HTMLInputElement>("mime"),
      };

      const stepOrder: StepId[] = [
        "signer",
        "name",
        "format",
        "file",
        "description",
        "advanced",
      ];

      const stepPanels = new Map<
        StepId,
        {
          panel: HTMLElement;
          body: HTMLElement;
          toggle: HTMLButtonElement;
          summary: HTMLElement | null;
          backButton: HTMLButtonElement | null;
          nextButton: HTMLButtonElement | null;
          caretButton: HTMLButtonElement;
          caretIcon: HTMLElement;
        }
      >();

      let missingStepNodes = false;
      for (const step of stepOrder) {
        const panel = root.querySelector<HTMLElement>(`[data-step-panel='${step}']`);
        const body = root.querySelector<HTMLElement>(`[data-step-body='${step}']`);
        const toggle = root.querySelector<HTMLButtonElement>(`[data-step-toggle='${step}']`);
        const summary = root.querySelector<HTMLElement>(`[data-step-summary='${step}']`);
        const backButton = root.querySelector<HTMLButtonElement>(`[data-step-back='${step}']`);
        const nextButton = root.querySelector<HTMLButtonElement>(`[data-step-next='${step}']`);
        const caretButton = root.querySelector<HTMLButtonElement>(`[data-step-caret='${step}']`);
        const caretIcon = root.querySelector<HTMLElement>(`[data-step-caret-icon='${step}']`);
        if (!panel || !body || !toggle || !caretButton || !caretIcon) {
          console.error(`[design-publish-form] missing step nodes for ${step}`);
          missingStepNodes = true;
          continue;
        }
        stepPanels.set(step, {
          panel,
          body,
          toggle,
          summary,
          backButton,
          nextButton,
          caretButton,
          caretIcon,
        });
      }

      if (missingStepNodes) {
        console.error("[design-publish-form] step panel initialization failed");
      } else {

      const sharedState = (window as Window & { __openprintsSignerState?: SharedSignerState })
        .__openprintsSignerState;

      const HACKER_MODE_STORAGE_KEY = "openprints:design-publish:hacker-mode";
      const apiBase = (root.getAttribute("data-api-base") ?? "").trim().replace(/\/$/, "");
      let signerPubkey = typeof sharedState?.pubkey === "string" ? sharedState.pubkey : "";
      const initialLnurl = sharedState?.lnurl ?? null;
      let isSigning = false;
      let isPublishing = false;
      let isHackerMode = false;
      let signedEvent: SignedNostrEvent | null = null;
      let publishedSuccess = false;
      let activeStep: StepId | null = "signer";
      let autoMovedFromSigner = false;
      let signerIdentityText = "Signer";
      let signerChipLabel = "";
      let signerDotState: "hidden" | "blinking" | "solid" = "hidden";
      const manualCompleted = new Set<StepId>();

      const CONTROL_OR_BIDI_RE = /[\u0000-\u001F\u007F-\u009F\u202A-\u202E\u2066-\u2069]/u;
      const FORMAT_RE = /^[a-z0-9][a-z0-9+.-]{0,31}$/;
      const SHA256_RE = /^[a-f0-9]{64}$/;
      const HEX_64_RE = /^[a-f0-9]{64}$/;
      const HEX_128_RE = /^[a-f0-9]{128}$/;
      const UUID_V4_RE =
        /^openprints:[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/;

      const fallbackUuidV4 = (): string => {
        const bytes = new Uint8Array(16);
        crypto.getRandomValues(bytes);
        bytes[6] = (bytes[6] & 0x0f) | 0x40;
        bytes[8] = (bytes[8] & 0x3f) | 0x80;
        const hex = Array.from(bytes, (b) => b.toString(16).padStart(2, "0")).join("");
        return `${hex.slice(0, 8)}-${hex.slice(8, 12)}-${hex.slice(12, 16)}-${hex.slice(16, 20)}-${hex.slice(20)}`;
      };

      const generateDesignId = (): string => {
        const uuid = typeof crypto.randomUUID === "function" ? crypto.randomUUID() : fallbackUuidV4();
        return `openprints:${uuid}`;
      };

      const setStatus = (message: string) => {
        signStatus.textContent = message;
      };

      const setSummary = (message: string) => {
        if (validationSummary) validationSummary.textContent = message;
      };

      const setHackerMode = (enabled: boolean) => {
        isHackerMode = enabled;
        for (const el of hackerFields) {
          el.classList.toggle("hidden", !enabled);
        }
        hackerToggleButton.setAttribute("aria-expanded", String(enabled));
        hackerToggleLabel.textContent = enabled ? "Hide advanced" : "Show advanced";
        try {
          window.localStorage.setItem(HACKER_MODE_STORAGE_KEY, enabled ? "1" : "0");
        } catch {
          // no-op
        }
      };

      const normalizeSingleLine = (value: string): string =>
        value.normalize("NFC").replace(/\s+/g, " ").trim();

      const normalizeTextArea = (value: string): string =>
        value.normalize("NFC").replace(/\r\n/g, "\n");

      const parseLineList = (value: string): string[] =>
        normalizeTextArea(value)
          .split("\n")
          .map((line) => line.trim())
          .filter((line) => line.length > 0);

      const hasInvalidTextContent = (value: string): boolean => CONTROL_OR_BIDI_RE.test(value);

      const asHttpsUrl = (value: string): string | null => {
        try {
          const url = new URL(value);
          return url.protocol === "https:" ? url.toString() : null;
        } catch {
          return null;
        }
      };

      const collectInputs = (): Inputs => ({
        d: fields.d.value,
        name: fields.name.value,
        format: (fields.format as unknown as HTMLSelectElement).value ?? fields.format.value,
        url: fields.url.value,
        sha256: fields.sha256.value,
        description: fields.description.value,
        preview: fields.preview.value,
        category: fields.category.value,
        material: fields.material.value,
        printer: fields.printer.value,
        license: fields.license.value,
        lnurl: fields.lnurl.value,
        mime: fields.mime.value,
      });

      const maybePrefillLnurl = (lnurl: string | null | undefined) => {
        const current = fields.lnurl.value;
        if (current && current.trim().length > 0) return;
        if (!lnurl) return;
        const normalized = normalizeSingleLine(lnurl);
        if (!normalized) return;
        fields.lnurl.value = normalized;
        refreshUnsignedPreview();
      };

      const buildUnsignedEvent = (inputs: Inputs, pubkey: string): BuildResult => {
        const errors: string[] = [];
        const warnings: string[] = [];

        const d = normalizeSingleLine(inputs.d).toLowerCase();
        if (!UUID_V4_RE.test(d)) errors.push("Design id is missing or invalid. Reload to generate a valid id.");

        const name = normalizeSingleLine(inputs.name);
        if (!name) errors.push("Name is required.");
        else if (name.length > 120) errors.push("Name must be at most 120 characters.");
        else if (hasInvalidTextContent(name)) errors.push("Name contains unsupported control or bidi characters.");

        const format = normalizeSingleLine(inputs.format).toLowerCase();
        if (!format) errors.push("Format is required.");
        else if (!FORMAT_RE.test(format)) errors.push("Format must be lowercase and use only [a-z0-9+.-].");

        const urlValue = normalizeSingleLine(inputs.url);
        const normalizedUrl = asHttpsUrl(urlValue);
        if (!normalizedUrl) errors.push("File URL must be a valid https URL.");

        const sha256Raw = normalizeSingleLine(inputs.sha256).toLowerCase();
        const sha256 = sha256Raw || "";
        if (sha256 && !SHA256_RE.test(sha256)) errors.push("SHA-256 must be exactly 64 lowercase hex characters.");
        else if (!sha256) warnings.push("No sha256 provided (allowed in V1).");

        const content = normalizeTextArea(inputs.description).trim();
        if (hasInvalidTextContent(content)) errors.push("Description contains unsupported control or bidi characters.");

        const previewValues = parseLineList(inputs.preview);
        const previewUrls: string[] = [];
        for (const preview of previewValues) {
          const url = asHttpsUrl(preview);
          if (!url) errors.push(`Preview URL is invalid: ${preview}`);
          else previewUrls.push(url);
        }

        const categoryValues = parseLineList(inputs.category).map((entry) => normalizeSingleLine(entry));
        const materialValues = parseLineList(inputs.material).map((entry) => normalizeSingleLine(entry));
        const printerValues = parseLineList(inputs.printer).map((entry) => normalizeSingleLine(entry));
        const license = normalizeSingleLine(inputs.license);
        const lnurl = normalizeSingleLine(inputs.lnurl);
        const mime = normalizeSingleLine(inputs.mime).toLowerCase();

        const textTagValues = [
          ...categoryValues,
          ...materialValues,
          ...printerValues,
          license,
          lnurl,
          mime,
        ].filter((v) => v.length > 0);

        for (const value of textTagValues) {
          if (hasInvalidTextContent(value)) errors.push(`Tag value contains unsupported control or bidi characters: ${value}`);
        }

        const normalizedPubkey = pubkey.trim().toLowerCase();
        if (!HEX_64_RE.test(normalizedPubkey)) errors.push("Signer pubkey is not available yet.");

        if (errors.length > 0) return { ok: false, errors };

        const tags: NostrTag[] = [
          ["d", d],
          ["name", name],
          ["format", format],
          ["url", normalizedUrl as string],
        ];

        if (sha256) tags.push(["sha256", sha256]);
        for (const previewUrl of previewUrls) tags.push(["preview", previewUrl]);
        for (const category of categoryValues) tags.push(["category", category]);
        for (const material of materialValues) tags.push(["material", material]);
        for (const printer of printerValues) tags.push(["printer", printer]);
        if (license) tags.push(["license", license]);
        if (lnurl) tags.push(["lnurl", lnurl]);
        if (mime) tags.push(["m", mime]);

        return {
          ok: true,
          event: {
            kind: 33301,
            created_at: Math.floor(Date.now() / 1000),
            pubkey: normalizedPubkey,
            tags,
            content,
          },
          warnings,
        };
      };

      const isSignerComplete = (): boolean => HEX_64_RE.test((signerPubkey || "").toLowerCase());
      const isNameComplete = (): boolean => {
        const name = normalizeSingleLine(fields.name.value);
        return name.length > 0 && name.length <= 120 && !hasInvalidTextContent(name);
      };
      const isFormatComplete = (): boolean => {
        const format = normalizeSingleLine((fields.format as unknown as HTMLSelectElement).value).toLowerCase();
        const mime = normalizeSingleLine(fields.mime.value).toLowerCase();
        if (!format || !FORMAT_RE.test(format)) return false;
        if (mime && hasInvalidTextContent(mime)) return false;
        return true;
      };
      const isFileComplete = (): boolean => {
        const url = normalizeSingleLine(fields.url.value);
        const sha = normalizeSingleLine(fields.sha256.value).toLowerCase();
        return !!asHttpsUrl(url) && (!sha || SHA256_RE.test(sha));
      };

      const getCompletionState = (): Record<StepId, boolean> => ({
        signer: isSignerComplete(),
        name: isNameComplete(),
        format: isFormatComplete(),
        file: isFileComplete(),
        description: manualCompleted.has("description"),
        advanced: manualCompleted.has("advanced"),
      });

      const hydrateSignerPubkeyFromSharedState = (): boolean => {
        if (isSignerComplete()) return true;
        const sharedPubkey = (
          window as Window & { __openprintsSignerState?: SharedSignerState }
        ).__openprintsSignerState?.pubkey;
        if (typeof sharedPubkey === "string" && HEX_64_RE.test(sharedPubkey.toLowerCase())) {
          signerPubkey = sharedPubkey;
          return true;
        }
        return false;
      };

      const isUnlocked = (step: StepId, completion: Record<StepId, boolean>): boolean => {
        const idx = stepOrder.indexOf(step);
        if (idx <= 0) return true;
        for (let i = 0; i < idx; i += 1) {
          if (!completion[stepOrder[i]]) return false;
        }
        return true;
      };

      const getFirstAvailableStep = (completion: Record<StepId, boolean>): StepId => {
        for (const step of stepOrder) {
          if (!completion[step] && isUnlocked(step, completion)) return step;
        }
        return "advanced";
      };

      const getValidationState = (
        step: StepId,
        completion: Record<StepId, boolean>,
      ): "empty" | "valid" | "invalid" => {
        if (completion[step]) return "valid";
        if (step === "signer") return "empty";
        if (step === "name") {
          const value = normalizeSingleLine(fields.name.value);
          return value.length === 0 ? "empty" : "invalid";
        }
        if (step === "format") {
          const format = normalizeSingleLine((fields.format as unknown as HTMLSelectElement).value).toLowerCase();
          return format.length === 0 ? "empty" : "invalid";
        }
        if (step === "file") {
          const hasAny = normalizeSingleLine(fields.url.value).length > 0 || normalizeSingleLine(fields.sha256.value).length > 0;
          return hasAny ? "invalid" : "empty";
        }
        if (step === "description") {
          return normalizeTextArea(fields.description.value).trim().length > 0 ? "valid" : "empty";
        }
        if (step === "advanced") {
          const hasLicense = normalizeSingleLine(fields.license.value).length > 0;
          const hasImages = parseLineList(fields.preview.value).length > 0;
          const hasCategories = parseLineList(fields.category.value).length > 0;
          const hasMaterials =
            parseLineList(fields.material.value).length > 0 || parseLineList(fields.printer.value).length > 0;
          const hasLnurl = normalizeSingleLine(fields.lnurl.value).length > 0;
          return hasLicense || hasImages || hasCategories || hasMaterials || hasLnurl ? "valid" : "empty";
        }
        return "empty";
      };

      const getSummary = (step: StepId): string => {
        switch (step) {
          case "signer":
            return isSignerComplete() ? "Signer ready" : "Waiting for signer";
          case "name": {
            const value = normalizeSingleLine(fields.name.value);
            return value || "Add a clear design name";
          }
          case "format": {
            const format = normalizeSingleLine((fields.format as unknown as HTMLSelectElement).value).toLowerCase();
            const mime = normalizeSingleLine(fields.mime.value).toLowerCase();
            if (!format) return "Choose the primary format";
            return mime ? `${format} (${mime})` : format;
          }
          case "file": {
            const hasUrl = !!asHttpsUrl(normalizeSingleLine(fields.url.value));
            const hasSha = normalizeSingleLine(fields.sha256.value).length > 0;
            if (!hasUrl) return "Add a file URL and optional digest";
            return hasSha ? "URL and SHA-256 set" : "URL set, SHA-256 optional";
          }
          case "description": {
            const text = normalizeTextArea(fields.description.value).trim();
            return text ? `${text.length} chars` : "No description";
          }
          case "advanced": {
            const hasLicense = normalizeSingleLine(fields.license.value).length > 0;
            const imageCount = parseLineList(fields.preview.value).length;
            const categoryCount = parseLineList(fields.category.value).length;
            const materialCount = parseLineList(fields.material.value).length;
            const printerCount = parseLineList(fields.printer.value).length;
            const hasLnurl = normalizeSingleLine(fields.lnurl.value).length > 0;
            const selected =
              Number(hasLicense) +
              Number(imageCount > 0) +
              Number(categoryCount > 0) +
              Number(materialCount > 0 || printerCount > 0) +
              Number(hasLnurl);
            return selected > 0 ? `${selected} section${selected === 1 ? "" : "s"} configured` : "Optional metadata";
          }
        }
      };

      const refreshSignerIdentityText = () => {
        const detectedChip =
          signerChipLabel ||
          root.querySelector<HTMLElement>("[data-panel-pill-label]")?.textContent?.trim() ||
          "";
        if (detectedChip) {
          signerIdentityText = detectedChip;
        } else if (isSignerComplete()) {
          signerIdentityText = `${signerPubkey.slice(0, 10)}...${signerPubkey.slice(-6)}`;
        } else {
          signerIdentityText = "Signer";
        }
        if (signerPill) {
          signerPill.classList.toggle("hidden", !isSignerComplete());
          signerPillText.textContent = signerIdentityText;
        }

        const dotState =
          signerDotState || (signerPanelHost?.dataset.signerDotState as "hidden" | "blinking" | "solid" | undefined) || "hidden";
        signerPillDot.classList.remove("nostr-status-dot--blinking");
        if (dotState === "blinking") {
          signerPillDot.classList.remove("hidden");
          signerPillDot.classList.add("nostr-status-dot--blinking");
        } else if (dotState === "solid") {
          signerPillDot.classList.remove("hidden");
        } else {
          signerPillDot.classList.add("hidden");
        }
      };

      const renderAccordion = () => {
        const completion = getCompletionState();

        for (const step of stepOrder) {
          const nodes = stepPanels.get(step);
          if (!nodes) continue;
          const validationState = getValidationState(step, completion);
          const open = step === activeStep;

          nodes.panel.dataset.validationState = validationState;
          nodes.panel.dataset.viewState = open ? "expanded" : "collapsed";
          nodes.body.classList.toggle("hidden", !open);
          nodes.caretIcon.classList.toggle("rotate-180", open);
          if (nodes.summary) nodes.summary.textContent = getSummary(step);
          nodes.toggle.disabled = false;
          nodes.toggle.classList.remove("opacity-60", "cursor-not-allowed");

          nodes.toggle.classList.toggle("hidden", open);
          nodes.toggle.classList.toggle("flex", !open);

          if (nodes.nextButton) {
            nodes.nextButton.disabled = false;
          }
        }

        refreshSignerIdentityText();
      };

      const openStep = (step: StepId) => {
        activeStep = step;
        renderAccordion();
      };

      const moveToNextStep = (step: StepId) => {
        const idx = stepOrder.indexOf(step);
        if (idx < 0 || idx >= stepOrder.length - 1) return;
        const next = stepOrder[idx + 1];
        openStep(next);
      };

      const moveToPreviousStep = (step: StepId) => {
        const idx = stepOrder.indexOf(step);
        if (idx <= 0) return;
        const previous = stepOrder[idx - 1];
        openStep(previous);
      };

      const maybeAutoAdvanceFromSigner = () => {
        if (isSignerComplete() && activeStep === "signer" && !autoMovedFromSigner) {
          activeStep = "name";
          autoMovedFromSigner = true;
        }
      };

      const refreshUnsignedPreview = () => {
        hydrateSignerPubkeyFromSharedState();
        maybeAutoAdvanceFromSigner();
        const result = buildUnsignedEvent(collectInputs(), signerPubkey);
        if (!result.ok) {
          unsignedOutput.value = "";
          setStatus(result.errors[0] ?? "Invalid form state.");
          setSummary("Waiting for signer and valid inputs.");
          signButton.disabled = true;
          publishButton.disabled = true;
          renderAccordion();
          return;
        }

        unsignedOutput.value = JSON.stringify(result.event, null, 2);
        const warningText =
          result.warnings.length > 0 ? ` Warning: ${result.warnings.join(" ")}` : "";
        setSummary(`Unsigned event is valid and deterministic.${warningText}`);

        const completion = getCompletionState();
        const signUnlocked = stepOrder.every((step) => completion[step]);
        signButton.disabled = isSigning || isPublishing || !signUnlocked;
        publishButton.disabled = !signedEvent || isPublishing;
        if (!signedEvent) setStatus("Ready to sign. Click \"Sign design event\".");

        renderAccordion();
      };

      const onSignerReady = (event: Event) => {
        const customEvent = event as CustomEvent<{ pubkey?: string | null }>;
        const pubkey = customEvent?.detail?.pubkey;
        if (typeof pubkey === "string" && pubkey.length > 0) {
          signerPubkey = pubkey;
          maybeAutoAdvanceFromSigner();
          refreshUnsignedPreview();
        }
      };

      const onIdentityMetadata = (event: Event) => {
        const customEvent = event as CustomEvent<IdentityMetadataDetail>;
        const detail = customEvent.detail;
        if (!detail) return;
        maybePrefillLnurl(detail.lnurl ?? null);
      };

      const onSignerViewChange = (event: Event) => {
        const customEvent = event as CustomEvent<SignerViewChangeDetail>;
        const detail = customEvent.detail;
        if (!detail) return;
        if (typeof detail.chipLabel === "string" && detail.chipLabel.trim().length > 0) {
          signerChipLabel = detail.chipLabel.trim();
        }
        if (detail.signedDot === "hidden" || detail.signedDot === "blinking" || detail.signedDot === "solid") {
          signerDotState = detail.signedDot;
        }
        hydrateSignerPubkeyFromSharedState();
        maybeAutoAdvanceFromSigner();
        refreshSignerIdentityText();
      };

      const validateSignedEvent = (
        event: Partial<SignedNostrEvent> | null | undefined,
      ): event is SignedNostrEvent => {
        if (!event || typeof event !== "object") return false;
        if (typeof event.id !== "string" || !HEX_64_RE.test(event.id.toLowerCase())) return false;
        if (typeof event.sig !== "string" || !HEX_128_RE.test(event.sig.toLowerCase())) return false;
        if (event.kind !== 33301) return false;
        if (!Array.isArray(event.tags)) return false;
        if (typeof event.pubkey !== "string" || !HEX_64_RE.test(event.pubkey.toLowerCase())) return false;
        if (typeof event.created_at !== "number") return false;
        if (typeof event.content !== "string") return false;
        return true;
      };

      const copyText = async (text: string) => {
        try {
          await navigator.clipboard.writeText(text);
          return true;
        } catch {
          return false;
        }
      };

      const handleCopySigned = async () => {
        const text = signedOutput.value;
        if (!text) return;
        const ok = await copyText(text);
        setStatus(ok ? "Copied signed JSON to clipboard." : "Copy failed. Your browser may block clipboard access.");
      };

      const clearSignedState = () => {
        signedEvent = null;
        publishedSuccess = false;
        signedOutput.value = "";
        copySignedBtn.disabled = true;
        copySignedBtnAdv.disabled = true;
        publishButton.disabled = true;
      };

      const handleSign = async () => {
        if (isSigning || isPublishing) return;

        const completion = getCompletionState();
        const signUnlocked = stepOrder.every((step) => completion[step]);
        if (!signUnlocked) {
          setStatus("Complete the previous steps before signing.");
          return;
        }

        const result = buildUnsignedEvent(collectInputs(), signerPubkey);
        if (!result.ok) {
          setStatus(result.errors[0] ?? "Cannot sign while form is invalid.");
          refreshUnsignedPreview();
          return;
        }

        const signer = (window as Window & { nostr?: NostrSigner }).nostr;
        if (!signer || typeof signer.signEvent !== "function") {
          setStatus("Nostr signer is unavailable.");
          signButton.disabled = true;
          return;
        }

        isSigning = true;
        signButton.disabled = true;
        setStatus("Waiting for signer confirmation...");

        try {
          const signed = await signer.signEvent(result.event);
          if (!validateSignedEvent(signed)) throw new Error("Signer returned an invalid event shape.");

          signedEvent = signed;
          publishedSuccess = false;
          signedOutput.value = JSON.stringify(signed, null, 2);
          copySignedBtn.disabled = false;
          copySignedBtnAdv.disabled = false;
          publishButton.disabled = false;
          setStatus("Event signed successfully. Continue to publish.");
        } catch (error) {
          const message = error instanceof Error ? error.message : "Unknown signer error";
          setStatus(`Signing failed: ${message}`);
          clearSignedState();
        } finally {
          isSigning = false;
          refreshUnsignedPreview();
        }
      };

      const parsePublishError = (payload: PublishResponse | null, fallback: string): string => {
        const fromPayload = payload?.errors?.find((entry) => typeof entry?.message === "string")?.message;
        return fromPayload && fromPayload.length > 0 ? fromPayload : fallback;
      };

      const handlePublish = async () => {
        if (isPublishing || isSigning) return;
        if (!signedEvent) {
          setStatus("Sign an event before publishing.");
          return;
        }
        if (!apiBase) {
          setStatus("API base URL is not configured. Set PUBLIC_OPENPRINTS_API_URL.");
          return;
        }

        isPublishing = true;
        publishButton.disabled = true;
        signButton.disabled = true;
        setStatus("Sending signed event to indexer API...");

        try {
          const controller = new AbortController();
          const timeout = window.setTimeout(() => controller.abort(), 20000);

          let response: Response;
          try {
            response = await fetch(`${apiBase}/designs/publish`, {
              method: "POST",
              headers: {
                "content-type": "application/json",
                accept: "application/json",
              },
              body: JSON.stringify(signedEvent),
              signal: controller.signal,
            });
          } finally {
            window.clearTimeout(timeout);
          }

          const payload = (await response.json().catch(() => null)) as PublishResponse | null;
          if (!response.ok || !payload?.ok) {
            const message = parsePublishError(payload, `Publish failed (${response.status}).`);
            setStatus(message);
            publishedSuccess = false;
            renderAccordion();
            return;
          }

          const accepted = payload.accepted_relay_count ?? 0;
          const duplicates = payload.duplicate_relay_count ?? 0;
          const rejected = payload.rejected_relay_count ?? 0;
          publishedSuccess = true;
          setStatus(
            `Published to ${accepted} relay${accepted === 1 ? "" : "s"} (${duplicates} duplicate ack, ${rejected} rejected).`,
          );
        } catch (error) {
          const message = error instanceof Error ? error.message : "unknown network error";
          publishedSuccess = false;
          setStatus(`Publish failed: ${message}`);
        } finally {
          isPublishing = false;
          const canSign = buildUnsignedEvent(collectInputs(), signerPubkey).ok;
          const completion = getCompletionState();
          signButton.disabled = !canSign || !stepOrder.every((step) => completion[step]);
          publishButton.disabled = !signedEvent;
          renderAccordion();
        }
      };

      const handleReset = () => {
        form.reset();
        fields.d.value = generateDesignId();
        manualCompleted.clear();
        clearSignedState();
        autoMovedFromSigner = false;
        hydrateSignerPubkeyFromSharedState();
        activeStep = isSignerComplete() ? "name" : "signer";
        setStatus("Form reset. Complete each step to sign and publish.");
        refreshUnsignedPreview();
      };

      const handleStepNext = (step: StepId) => {
        if (step === "description" || step === "advanced") {
          manualCompleted.add(step);
          renderAccordion();
        }

        moveToNextStep(step);
      };

      // init
      fields.d.value = generateDesignId();
      if (initialLnurl) maybePrefillLnurl(initialLnurl);

      const allWatchFields: (HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement)[] =
        Object.values(fields).filter((field) => field !== fields.d) as any;

      for (const field of allWatchFields) {
        const onChange = () => {
          if (signedEvent) clearSignedState();
          refreshUnsignedPreview();
        };
        field.addEventListener("input", onChange);
        field.addEventListener("change", onChange);
      }

      for (const step of stepOrder) {
        const nodes = stepPanels.get(step);
        if (!nodes) continue;
        nodes.toggle.addEventListener("click", () => openStep(step));
        nodes.backButton?.addEventListener("click", () => moveToPreviousStep(step));
        nodes.nextButton?.addEventListener("click", () => handleStepNext(step));
        nodes.caretButton.addEventListener("click", (event) => {
          event.preventDefault();
          event.stopPropagation();
          activeStep = activeStep === step ? null : step;
          renderAccordion();
        });
      }

      signButton.addEventListener("click", () => void handleSign());
      publishButton.addEventListener("click", () => void handlePublish());
      resetButton.addEventListener("click", handleReset);

      copySignedBtn.addEventListener("click", () => void handleCopySigned());
      copySignedBtnAdv.addEventListener("click", () => void handleCopySigned());

      hackerToggleButton.addEventListener("click", () => setHackerMode(!isHackerMode));

      document.addEventListener("nostr-signer-ready", onSignerReady);
      document.addEventListener("openprints-identity-metadata", onIdentityMetadata);
      document.addEventListener("openprints-signer-view-change", onSignerViewChange);

      try {
        setHackerMode(window.localStorage.getItem(HACKER_MODE_STORAGE_KEY) === "1");
      } catch {
        setHackerMode(false);
      }

        activeStep = isSignerComplete() ? "name" : "signer";
        refreshUnsignedPreview();
        if (signerPubkey) {
          setStatus("Signer detected. Continue with the next step.");
        } else {
          setStatus("Waiting for signer pubkey...");
        }
        renderAccordion();
      }
    }
  }
</script>

<style>
  .nostr-status-dot--blinking {
    animation: nostrStatusBlink 1.2s infinite ease-in-out;
  }

  @keyframes nostrStatusBlink {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 1;
    }
  }
</style>