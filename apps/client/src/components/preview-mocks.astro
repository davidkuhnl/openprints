---
interface Props {
  count?: number;
  /** "card" = lighter, smaller thumbnails for result cards */
  variant?: "default" | "card";
}

const { count = 3, variant = "default" } = Astro.props as Props;
const isCard = variant === "card";

const baseBoxClass =
  "flex items-center justify-center rounded-md border shrink-0";

const boxClass = isCard
  ? `${baseBoxClass} h-24 w-24 border-default/40 bg-default/20`
  : `${baseBoxClass} h-28 w-28 border-default bg-gradient-to-br from-slate-700/25 via-slate-600/20 to-slate-500/25`;
---

<div class="flex flex-wrap gap-1.5">
  {Array.from({ length: count }).map((_, i) => (
    <div class={boxClass} aria-hidden="true">
      <span class="text-[9px] tracking-[0.12em] text-offset/60">mock</span>
    </div>
  ))}
</div>