---
import { Icon } from "astro-icon/components";
import TimestampDisplay from "~/components/timestamp-display.astro";
import type { IdentityDetailModel } from "~/lib/identities";

interface Props {
  identity: IdentityDetailModel | null | undefined;
}

const { identity } = Astro.props as Props;

const rawStatus = identity?.status as string | null | undefined;
const normalizedStatus =
  typeof rawStatus === "string" ? rawStatus.trim().toLowerCase() : null;

const statusLabel =
  normalizedStatus === "pending"
    ? "Waiting on relays"
    : normalizedStatus === "fetched"
    ? "Seen on relays"
    : normalizedStatus === "failed"
    ? "Not on relays"
    : rawStatus || "Nostr status";

const iconName = "mdi:radio-tower";

const statusAccent =
  normalizedStatus === "pending"
    ? "#38bdf8"
    : normalizedStatus === "failed"
    ? "#fb7185"
    : "#34d399";

const statusBg =
  normalizedStatus === "pending"
    ? "rgba(56, 189, 248, 0.12)"
    : normalizedStatus === "failed"
    ? "rgba(251, 113, 133, 0.12)"
    : "rgba(52, 211, 153, 0.12)";

function getDateFromInput(input: unknown): Date | null {
  if (input == null) return null;

  const n = typeof input === "number" ? input : Number(input);
  if (!Number.isFinite(n)) return null;

  const ms = n > 1e12 ? n : n * 1000;
  const d = new Date(ms);
  if (Number.isNaN(d.getTime())) return null;

  return d;
}
---

{rawStatus && (
  <details
    class="group inline-block text-[10px] text-offset"
    style={`--status-accent: ${statusAccent}; --status-bg: ${statusBg};`}
  >
    {/* PILL (shown when collapsed) – same structure as the other pills */}
    <summary
      class="inline-flex cursor-pointer list-none items-center gap-1 rounded-md border border-default bg-default/40 px-2 py-1 group-open:hidden"
    >
      <Icon
        name={iconName}
        class="size-3"
        style={`color: ${statusAccent};`}
        aria-hidden="true"
      />
      <span class="text-default">
        {statusLabel}
      </span>
      <Icon
        name="mdi:plus"
        class="size-2.5 shrink-0 text-offset/70 transition group-hover:text-default"
        aria-hidden="true"
      />
    </summary>

    {/* INLINE PANEL (shown when expanded, replaces pill) */}
    <div class="mt-0 hidden group-open:block">
      <div
        class="rounded-md border border-default/60 border-l-2 border-l-[var(--status-accent)] bg-offset/90 px-2 py-1 text-[10px] leading-[1.3] text-offset shadow-sm backdrop-blur-sm -ml-px"
        data-status-panel
      >
        {/* header row – same icon/label sizing as the collapsed pill, nudged down slightly for alignment */}
        <div class="flex items-center justify-between gap-2">
          <span class="inline-flex min-w-0 items-center gap-1 translate-y-[2.5px]">
            <Icon
              name={iconName}
              class="size-3 shrink-0"
              style={`color: ${statusAccent};`}
              aria-hidden="true"
            />
            <span class="text-default truncate">
              {statusLabel}
            </span>
          </span>

          {/* subtle close button */}
          <button
            type="button"
            class="inline-flex size-3 shrink-0 items-center justify-center rounded-full text-[10px] text-offset/70 hover:bg-default/20 hover:text-default transition"
            aria-label="Close status details"
            data-close-status-panel
          >
            <Icon
              name="mdi:close"
              class="size-2.5"
              aria-hidden="true"
            />
          </button>
        </div>

        {/* body text – can be a bit looser */}
        <div class="mt-1 space-y-1 text-[11px] leading-relaxed">
          {/* Pending */}
          {normalizedStatus === "pending" && (
            <p class="text-offset/70">
              We’ve just noticed this npub and we’re still waiting to hear about it
              from the connected relays. Hang in there.
            </p>
          )}

          {/* Fetched */}
          {normalizedStatus === "fetched" && (
            <div class="space-y-1">
              <p class="text-offset/80">
                Oh, we know this npub well.
                {identity?.pubkey_first_seen_at && (
                  <>
                    {" "}
                    We first saw them in OpenPrints on{" "}
                    <span class="font-semibold text-default">
                      {getDateFromInput(identity.pubkey_first_seen_at)?.toLocaleDateString(
                        undefined,
                        { year: "numeric", month: "short", day: "2-digit" },
                      )}
                    </span>
                    .
                  </>
                )}
                {identity?.pubkey_last_seen_at && (
                  <>
                    {" "}
                    They were last active{" "}
                    <span class="font-semibold text-default">
                      <TimestampDisplay
                        value={identity.pubkey_last_seen_at}
                        agoFormat={true}
                      />
                    </span>
                    .
                  </>
                )}
                {identity?.profile_fetched_at && (
                  <>
                    {" "}
                    We got their fresh info from the relays{" "}
                    <span class="font-semibold text-default">
                      <TimestampDisplay
                        value={identity.profile_fetched_at}
                        agoFormat={true}
                      />
                    </span>
                    .
                  </>
                )}
              </p>
            </div>
          )}

          {/* Failed */}
          {normalizedStatus === "failed" && (
            <div class="space-y-1">
              {typeof identity?.retry_count === "number" &&
                identity.retry_count > 0 && (
                  <p class="text-offset/70">
                    We’ve already checked the connected relays{" "}
                    <span class="font-semibold text-default">
                      {identity.retry_count}
                    </span>{" "}
                    time{identity.retry_count === 1 ? "" : "s"}, but we haven’t seen a
                    kind-0 event for this npub yet. Stay tuned.
                  </p>
              )}
            </div>
          )}
        </div>
      </div>
    </div>





    </div>
  </details>
)}

<script>
  if (typeof window !== "undefined") {
    window.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      // Close via explicit "x" button
      const closeButton = target.closest("[data-close-status-panel]");
      if (closeButton) {
        const detailsEl = closeButton.closest("details");
        if (detailsEl) {
          detailsEl.open = false;
        }
        return;
      }

      // Close when clicking anywhere on the expanded status panel
      const panelEl = target.closest("[data-status-panel]");
      if (panelEl) {
        const detailsEl = panelEl.closest("details");
        if (detailsEl) {
          detailsEl.open = false;
        }
      }
    });
  }
</script>