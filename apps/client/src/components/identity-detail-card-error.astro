---
interface Props {
  errorTitle?: string | null;
  errorMessage: string;
}

const { errorTitle = null, errorMessage } = Astro.props as Props;
---

<article class="mx-auto flex max-w-5xl flex-col gap-2.5 rounded-xl border border-default bg-offset/30 p-4 sm:p-5">
  <h1 class="text-lg font-semibold tracking-tight">
    {errorTitle ?? "Identity not found"}
  </h1>
  <p class="mt-1.5 text-xs text-offset">{errorMessage}</p>
</article>
