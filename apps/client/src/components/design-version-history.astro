---
// TODO: This is not currently used and we might want to remove it. It does have the dif components in it that we used to use and might want to repurpose.
import TimestampDisplay from "~/components/timestamp-display.astro";
import TruncateCopy from "~/components/truncate-copy.astro";
import CopyValue from "~/components/copy-value.astro";
import type { ValidDesignVersion } from "~/lib/designs";
import { prettyJsonFromValue } from "~/lib/json";

interface Props {
  versions: ValidDesignVersion[];
  total: number;
}

type SnapshotValue = string | null;

interface SnapshotField {
  key: string;
  label: string;
  value: SnapshotValue;
}

interface ChangeRow {
  key: string;
  label: string;
  before: SnapshotValue;
  after: SnapshotValue;
}

const { versions, total } = Astro.props as Props;

const toSingleLine = (value: string): string => value.replace(/\s+/g, " ").trim();

const normalized = (value: SnapshotValue): string => (value ?? "").trim();

const pretty = (value: SnapshotValue): string => {
  const out = normalized(value);
  return out.length > 0 ? out : "—";
};

const asTagsString = (value: unknown): string => {
  return prettyJsonFromValue(value ?? {});
};

const toSnapshotFields = (version: ValidDesignVersion): SnapshotField[] => [
  { key: "name", label: "Name", value: version.name },
  { key: "format", label: "Format", value: version.format },
  { key: "url", label: "File URL", value: version.url },
  { key: "sha256", label: "SHA-256", value: version.sha256 },
  { key: "content", label: "Description", value: version.content },
  { key: "tags", label: "Tags JSON", value: asTagsString(version.tags_json) },
];

const computeChanges = (current: ValidDesignVersion, previous?: ValidDesignVersion): ChangeRow[] => {
  if (!previous) return [];
  const currentFields = toSnapshotFields(current);
  const previousByKey = new Map(toSnapshotFields(previous).map((field) => [field.key, field.value]));

  return currentFields
    .map((field) => ({
      key: field.key,
      label: field.label,
      before: previousByKey.get(field.key) ?? null,
      after: field.value,
    }))
    .filter((row) => normalized(row.before) !== normalized(row.after));
};

const hasHiddenOlder = versions.length < total;
const latestVersion = versions[0];
---

<section class="mt-4 border-t border-default/70 pt-4">
  <header class="pb-1">
    <div>
      <p class="text-[10px] font-medium uppercase tracking-[0.14em] text-offset">Version history</p>
      <p class="mt-1 text-[11px] leading-relaxed text-offset/80">Signed updates for this design.</p>
    </div>
  </header>

  {versions.length === 0 ? (
    <p class="mt-3 text-xs text-offset">No versions were returned by the API for this design yet.</p>
  ) : (
    <>
      <div class="mt-2 flex flex-wrap items-center gap-1.5 py-1 text-[10px] text-offset/80">
        <span class="inline-flex items-center rounded-md border border-default/40 px-1.5 py-0.5 font-medium text-default">
          {total} {total === 1 ? "version" : "versions"}
        </span>
        <span class="text-offset/50">•</span>
        <span>Latest change</span>
        <span class="font-medium text-default">update</span>
        {latestVersion?.created_at && (
          <>
            <span class="text-offset/50">•</span>
            <span>Updated</span>
            <span class="text-default">
              <TimestampDisplay value={latestVersion.created_at} />
            </span>
          </>
        )}
      </div>

      <ol class="mt-2 divide-y divide-default/50">
      {versions.map((version, index) => {
        const versionNumber = total - index;
        const previous = versions[index + 1];
        const changes = computeChanges(version, previous);
        const hasBaseline = Boolean(previous);
        const eventJsonTextareaId = `design-version-event-json-${index}`;
        return (
          <li>
            <details class="group">
              <summary class="list-none cursor-pointer py-2">
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <div class="flex min-w-0 items-center gap-2.5">
                    <span class="text-xs font-semibold text-default">Version {versionNumber}</span>
                    <span class="text-[11px] text-offset">
                      <TimestampDisplay value={version.created_at} />
                    </span>
                    <span class="inline-flex items-center rounded-md border border-default/40 px-1.5 py-0.5 text-[9px] font-medium text-offset/85">
                      update
                    </span>
                  </div>
                  <div class="flex min-w-0 items-center gap-1 text-[9px] text-offset/60">
                    <span class="font-mono text-offset/60">
                      <TruncateCopy value={version.event_id} maxChars={12} />
                    </span>
                  </div>
                </div>
              </summary>
              <div class="space-y-3 border-t border-default/60 pb-3 pt-2.5">
                <div class="space-y-1">
                  <p class="text-[10px] font-medium uppercase tracking-[0.12em] text-offset">
                    Diff against previous version
                  </p>
                  {!hasBaseline ? (
                    <p class="text-[11px] text-offset/80">
                      {hasHiddenOlder && index === versions.length - 1
                        ? "Load older versions to compare this version against its predecessor."
                        : "This is the earliest known version in the current history."}
                    </p>
                  ) : changes.length === 0 ? (
                    <p class="text-[11px] text-offset/80">No field-level changes detected.</p>
                  ) : (
                    <ul class="divide-y divide-default/40">
                      {changes.map((change) => (
                        <li class="border-l border-default/60 py-1.5 pl-2 text-[11px]">
                          <p class="font-medium text-default">{change.label}</p>
                          <p class="mt-0.5 text-offset/80">
                            <span class="font-medium text-offset/70">Before:</span>{" "}
                            <span class="break-all">{toSingleLine(pretty(change.before))}</span>
                          </p>
                          <p class="mt-0.5 text-offset/80">
                            <span class="font-medium text-offset/70">After:</span>{" "}
                            <span class="break-all">{toSingleLine(pretty(change.after))}</span>
                          </p>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>

                <div class="space-y-1">
                  <p class="text-[10px] font-medium uppercase tracking-[0.12em] text-offset">
                    Snapshot
                  </p>
                  <dl class="grid gap-x-4 gap-y-2 sm:grid-cols-2">
                    {toSnapshotFields(version).map((field) => (
                      <div class="border-l border-default/60 py-1 pl-2">
                        <dt class="text-[10px] uppercase tracking-[0.12em] text-offset/80">{field.label}</dt>
                        <dd class="mt-0.5 break-all text-[11px] text-default">{pretty(field.value)}</dd>
                      </div>
                    ))}
                  </dl>
                </div>

                <div class="space-y-1">
                  <div class="flex items-center justify-between gap-2">
                    <p class="text-[10px] font-medium uppercase tracking-[0.12em] text-offset">
                      Signed event JSON
                    </p>
                    <CopyValue
                      sourceSelector={`#${eventJsonTextareaId}`}
                      showLabel={true}
                      label="Copy"
                      title="Copy event JSON"
                      buttonClass="h-auto w-auto rounded-md border border-default/70 px-2.5 py-1.5 text-[11px] text-offset hover:bg-default/20 hover:text-default focus-visible:ring-2 focus-visible:ring-emerald-300/60"
                    />
                  </div>
                  <textarea
                    id={eventJsonTextareaId}
                    rows="8"
                    readonly
                    class="min-h-[180px] w-full resize-y rounded-md border border-default/60 bg-transparent px-3 py-2 font-mono text-[11px] leading-relaxed text-default focus:outline-none"
                  >{version.raw_event_json}</textarea>
                </div>
              </div>
            </details>
          </li>
        );
      })}
      </ol>
    </>
  )}

  {hasHiddenOlder && (
    <p class="mt-2 text-[11px] text-offset/80">
      Showing latest {versions.length} of {total} versions.
    </p>
  )}
</section>
