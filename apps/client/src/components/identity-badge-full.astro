---
import CopyValue from "~/components/copy-value.astro";
import IdentityAvatar from "~/components/identity-avatar.astro";
import { getIdentityStatusFlags } from "~/lib/identity-status";
import { Icon } from "astro-icon/components";
import type { CreatorIdentityCard } from "~/lib/designs";

interface Props {
  identity: CreatorIdentityCard;
}

const { identity } = Astro.props;

const displayNameResolved = identity.display_name_resolved;
const npub = identity.npub;
const identityHref = `/app/identity/${encodeURIComponent(identity.pubkey)}`;

const { hasNip05, isZappable } = getIdentityStatusFlags(identity);
---

<div class="inline-flex items-center">
  <div class="inline-flex items-center">
    <div class="relative z-10">
      <IdentityAvatar
        picture={identity.picture}
        shape={identity.shape}
        pubkey={identity.pubkey}
        size={50}
        alt={displayNameResolved}
      />
    </div>

    <span class="inline-flex items-center gap-1.5 rounded-md border border-default px-2 py-1 text-[10px] text-offset -ml-3 pl-5">
      <span class="font-medium truncate max-w-[160px]">
        {identityHref ? (
          <a
            href={identityHref}
            class="underline-offset-2 hover:underline focus:outline-none focus-visible:outline-none"
          >
            {displayNameResolved}
          </a>
        ) : (
          displayNameResolved
        )}
      </span>

      {isZappable && (
        <Icon
          name="mdi:lightning-bolt"
          class="size-3.5 shrink-0 text-emerald-400"
          title="Zappable"
          aria-hidden="true"
        />
      )}

      {hasNip05 && (
        <Icon
          name="mdi:check-decagram"
          class="size-3.5 shrink-0 text-emerald-400"
          title="NIP05 verified!"
          aria-hidden="true"
        />
      )}

      {npub && (
        <CopyValue value={npub} title="Copy npub" />
      )}
    </span>
  </div>
</div>

