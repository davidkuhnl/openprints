---
import IdentityBadgeCompact from "~/components/identity-badge-compact.astro";
import IdentityBadgeFull from "~/components/identity-badge-full.astro";

/** Creator identity from API (creator_identity field on design). Backend guarantees pubkey, display_name_resolved, npub. */
interface CreatorIdentity {
  id?: string | null;
  status: string | null;
  pubkey: string;
  display_name_resolved: string;
  npub: string;
  picture?: string | null;
  nip05?: string | null;
  lud06?: string | null;
  lud16?: string | null;
}

interface Props {
  identity: CreatorIdentity | null | undefined;
  size?: "full" | "compact" | "responsive";
}

const { identity, size = "full" } = Astro.props;
---

{size === "compact" && (
  <IdentityBadgeCompact identity={identity} />
)}

{size === "full" && (
  <IdentityBadgeFull identity={identity} />
)}

{size === "responsive" && (
  <div class="identity-badge identity-badge--responsive inline-flex items-center">
    <div class="identity-badge__full">
      <IdentityBadgeFull identity={identity} />
    </div>

    <div class="identity-badge__compact">
      <IdentityBadgeCompact identity={identity} />
    </div>
  </div>
)}