---
import { getIdentityStatusFlags } from "~/lib/identity-status";
import TruncateCopy from "~/components/truncate-copy.astro";
import IdentityAvatar from "~/components/identity-avatar.astro";
import IdentityBanner from "~/components/identity-banner.astro";
import IconPill from "~/components/icon-pill.astro";
import IdentityNostrStatus from "~/components/identity-nostr-status.astro";
import RecentDesignsGrid from "~/components/recent-designs-grid.astro";
import { nounForCount } from "~/lib/plural";
import { Icon } from "astro-icon/components";
import type { IdentityDetailModel } from "~/lib/identities";

interface Props {
  identity: IdentityDetailModel;
  identityId: string;
  totalDesignsForIdentity?: number | null;
  totalVersionsForIdentity?: number | null;
  designsPreviewLimit?: number;
  showPublishActions?: boolean;
  publishHref?: string;
}

const {
  identity,
  identityId,
  totalDesignsForIdentity = null,
  totalVersionsForIdentity = null,
  designsPreviewLimit = 6,
  showPublishActions = false,
  publishHref = "/app/designs/new",
} = Astro.props as Props;

const identityIdParam: string = typeof identityId === "string" ? identityId : "";
const displayName = identity.display_name_resolved;
const { hasNip05, isZappable } = getIdentityStatusFlags(identity);
const hasProfileFields = identity.nip05 || identity.website || identity.lud16;

const totalDesignsDisplay = totalDesignsForIdentity ?? "—";
const totalVersionsDisplay = totalVersionsForIdentity ?? "—";

const showAllDesignsButton =
  typeof totalDesignsForIdentity === "number" &&
  totalDesignsForIdentity > designsPreviewLimit;
const showEmptyPublishButton =
  showPublishActions && totalDesignsForIdentity === 0;

const designsLabel = nounForCount(totalDesignsForIdentity ?? 0, {
  one: "design",
  other: "designs",
});

const versionsLabel = nounForCount(totalVersionsForIdentity ?? 0, {
  one: "version",
  other: "versions",
});
---

<article class="mx-auto flex max-w-5xl flex-col gap-2.5 rounded-xl border border-default bg-offset/30 p-4 sm:p-5">
  <div>
    <header class="border-b border-default pb-4">
      <IdentityBanner pubkey={identity.pubkey} />

      <div class="flex items-start gap-[18px] px-4 sm:px-5 -mt-8">
        <div class="shrink-0 inline-flex">
          <IdentityAvatar
            picture={identity.picture}
            shape={identity.shape}
            pubkey={identity.pubkey}
            size={110}
            alt={displayName}
            hover={true}
          />
        </div>

        <div class="flex flex-col gap-2 pt-9">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="flex items-center gap-1">
              <h1 class="text-3xl font-semibold tracking-tight leading-tight">
                {displayName}
              </h1>
              {isZappable && (
                <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-emerald-400/10 text-emerald-400 translate-y-[3px] transition-all duration-150 hover:scale-110 hover:bg-emerald-400/15 hover:shadow-[0_0_4px_1px_rgba(16,185,129,0.25)]">
                  <Icon name="mdi:lightning-bolt" class="w-3 h-3" title="Zappable" aria-hidden="true" />
                </span>
              )}
              {hasNip05 && (
                <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-emerald-400/10 text-emerald-400 translate-y-[3px] transition-all duration-150 hover:scale-110 hover:bg-emerald-400/15 hover:shadow-[0_0_4px_1px_rgba(16,185,129,0.25)]">
                  <Icon name="mdi:check-decagram" class="w-3 h-3" title="NIP05 Verified" aria-hidden="true" />
                </span>
              )}
            </div>

            {showPublishActions && (
              <a
                href={publishHref}
                class="inline-flex items-center justify-center gap-1.5 ml-5 rounded-md border border-emerald-400/40 bg-emerald-400/10 px-4 py-2.5 text-xs font-semibold text-default transition hover:bg-emerald-400/20 hover:text-emerald-400"
              >
                Publish design
                <span aria-hidden="true">→</span>
              </a>
            )}
          </div>

          {identity.npub && (
            <div class="text-xs text-offset">
              <TruncateCopy value={identity.npub} maxChars={20} />
            </div>
          )}

          <div class="flex flex-wrap items-center gap-2 text-[10px] text-offset">
            <IdentityNostrStatus identity={identity} />
            <IconPill icon="mdi:shape-outline">
              <span class="text-default">
                {totalDesignsDisplay}
              </span>
              {designsLabel}
            </IconPill>

            <IconPill icon="mdi:layers-outline">
              <span class="text-default">
                {totalVersionsDisplay}
              </span>
              {versionsLabel}
            </IconPill>
          </div>
        </div>
      </div>
    </header>

    <section class="mt-4 grid gap-4 md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-offset">
          About
        </h2>
        <p class="mt-2 text-xs leading-relaxed text-offset">
          {identity.about || "No additional information provided for this identity yet."}
        </p>
      </div>

      <div class="space-y-4">
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-offset">
            Keys
          </h2>
          <div class="mt-2 space-y-1 text-xs text-offset">
            {identity.npub && (
              <p>
                <span class="mr-1 font-medium text-default">npub:</span>
                <TruncateCopy value={identity.npub} maxChars={20} />
              </p>
            )}
            <p>
              <span class="mr-1 font-medium text-default">pubkey:</span>
              <TruncateCopy value={identity.pubkey} maxChars={20} />
            </p>
          </div>
        </div>

        {hasProfileFields && (
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-offset">
              Profile
            </h2>
            <div class="mt-2 space-y-1 text-xs text-offset">
              {identity.nip05 && (
                <p>
                  <span class="mr-1 font-medium text-default">nip05:</span>
                  {identity.nip05}
                </p>
              )}
              {identity.website && (
                <p>
                  <span class="mr-1 font-medium text-default">website:</span>
                  <a
                    href={identity.website}
                    target="_blank"
                    rel="noreferrer"
                    class="underline-offset-2 hover:underline"
                  >
                    {identity.website}
                  </a>
                </p>
              )}
              {identity.lud16 && (
                <p>
                  <span class="mr-1 font-medium text-default">lud16:</span>
                  {identity.lud16}
                </p>
              )}
            </div>
          </div>
        )}
      </div>
    </section>

    <section class="relative mt-4 border-t border-default/60 pt-4">
      <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-offset">
        Latest designs
        <span
          class="ml-1 text-offset/70 normal-case inline-block max-w-[220px] truncate align-bottom"
          title={displayName}
        >
          · {displayName}
        </span>
      </h2>

      <div class="mt-3">
        <RecentDesignsGrid
          limit={designsPreviewLimit}
          identityId={identityId}
          emptyMessage="This user hasn't published any designs yet."
          emptyActionHref={showEmptyPublishButton ? publishHref : null}
          emptyActionLabel={showEmptyPublishButton ? "Publish your first design" : null}
        />
      </div>

      {showAllDesignsButton && (
        <div class="mt-3 flex justify-end">
          <a
            href={`/app/designs?identity_id=${encodeURIComponent(identityIdParam)}`}
            class="inline-flex items-center gap-1.5 rounded-md border border-default/60 bg-default/20 px-2 py-1 text-[11px] text-offset transition hover:bg-default/30 hover:text-default"
          >
            View all {totalDesignsForIdentity} designs
            <span class="text-offset/70">→</span>
          </a>
        </div>
      )}
    </section>
  </div>
</article>
