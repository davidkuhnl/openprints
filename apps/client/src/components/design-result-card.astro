---
import type { DesignCardModel } from "~/lib/designs";
import DesignResultCardValid from "~/components/design-result-card-valid.astro";
import DesignResultCardInvalid from "~/components/design-result-card-invalid.astro";

interface Props {
  design: DesignCardModel;
}

const { design } = Astro.props;
---

{
  design.kind === "invalid" ? (
    <DesignResultCardInvalid design={design} />
  ) : (
    <DesignResultCardValid design={design} />
  )
}
