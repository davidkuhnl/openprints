---
import Pubkey from "~/components/pubkey.astro";
import TimestampDisplay from "~/components/timestamp-display.astro";
import PreviewMocks from "~/components/preview-mocks.astro";
import { Icon } from "astro-icon/components";
import IdentityBadge from "~/components/identity-badge.astro";

interface Props {
  design: {
    id: string;
    name?: string | null;
    content?: string | null;
    pubkey?: string | null;
    latest_published_at?: unknown;
    format?: string | null;
    tags_json?: unknown;
  };
}

const { design } = Astro.props;
const name = design.name || "Untitled design";
const description =
  typeof design.content === "string" ? design.content.trim() : "";
const excerpt =
  description.length > 120 ? `${description.slice(0, 120)}…` : description;

let previewImages: string[] = [];

if (design.tags_json) {
  try {
    const rawTags =
      typeof design.tags_json === "string"
        ? JSON.parse(design.tags_json)
        : design.tags_json;

    const previews = rawTags && (rawTags as any).preview;

    if (Array.isArray(previews)) {
      previewImages = previews.filter(
        (item: unknown): item is string =>
          typeof item === "string" && item.trim().length > 0
      );
    }
  } catch {
    // Ignore malformed tags_json
  }
}
---

<article class="flex flex-col gap-1 rounded-xl border border-default bg-offset/30 px-3.5 py-2.5 sm:px-4 sm:py-3 transition hover:bg-offset/40 hover:border-emerald-400/40">
  <!-- (1) HEADER BLOCK -->
  <header class="pb-2 mb-2 border-b border-default/60">
    <h2 class="text-sm font-medium text-default">
      <a
        href={`/app/designs/${encodeURIComponent(design.id)}`}
        class="underline-offset-2 hover:underline"
      >
        {name}
      </a>
    </h2>

    <div class="mt-1 mb-1.5 flex flex-wrap items-center gap-3 text-[11px] text-offset">
       <IdentityBadge identity={design.creator_identity} size="compact" />
      {design.latest_published_at != null && (
        <span class="inline-flex items-center gap-1">
          <Icon
            name="mdi:clock-outline"
            class="size-3 text-offset"
            aria-hidden="true"
          />
          <TimestampDisplay value={design.latest_published_at} agoFormat />
        </span>
      )}

      {design.format && (
        <span class="inline-flex items-center gap-1 text-emerald-400/80">
          <Icon
            name="mdi:file-outline"
            class="size-3 text-offset"
            aria-hidden="true"
          />
          {design.format}
        </span>
      )}
    </div>
  </header>

  <!-- (2) SHORT DESCRIPTION -->
  {excerpt && (
    <p class="mb-2 text-xs text-offset line-clamp-2">
      {excerpt}
    </p>
  )}

  <!-- (3) THUMBNAIL STRIP -->
  <div class="mt-1.5 flex justify-end">
    {previewImages.length > 0 ? (
      <div class="flex flex-wrap gap-1.5">
        {previewImages.map((src) => (
          <img
            src={src}
            loading="lazy"
            alt={`Preview of ${name}`}
            class="h-16 w-16 shrink-0 rounded-md border border-default/40 bg-default/20 object-cover"
          />
        ))}
      </div>
    ) : (
      <PreviewMocks count={3} variant="card" />
    )}
  </div>
</article>