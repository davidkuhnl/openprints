---
const apiBaseUrl = import.meta.env.PUBLIC_OPENPRINTS_API_URL ?? "";
---

<section class="designs-list space-y-4" data-api-base-url={apiBaseUrl}>
  <p class="text-offset">Loading designs…</p>
</section>

<script define:vars={{ apiBaseUrl }}>
  (function () {
    const base =
      typeof apiBaseUrl === "string" && apiBaseUrl
        ? apiBaseUrl.replace(/\/$/, "")
        : "";
    if (!base) return;

    const root = document.querySelector(".designs-list");
    if (!root) return;

    const url = `${base}/designs?limit=50&order=latest_published_at_desc`;

    fetch(url)
      .then((res) => (res.ok ? res.json() : Promise.reject(new Error(res.statusText))))
      .then((data) => {
        const items = (data && data.items) || [];
        if (!items.length) {
          root.innerHTML = '<p class="text-offset">No designs yet.</p>';
          return;
        }

        const list = document.createElement("ul");
        list.className =
          "overflow-hidden rounded-xl border border-default bg-offset/40";

        for (const d of items) {
          const li = document.createElement("li");
          li.className = "flex flex-col gap-1.5 border-b border-default p-3.5 last:border-b-0 sm:p-4";

          const name = d.name || "Untitled design";

          li.innerHTML = `
            <a href="/app/designs/detail?id=${encodeURIComponent(
              d.id,
            )}" class="text-sm font-medium tracking-tight text-default hover:underline">
              ${name}
            </a>
            <p class="text-[10px] text-offset break-all">By ${d.pubkey}</p>
          `;

          list.appendChild(li);
        }

        root.innerHTML = "";
        root.appendChild(list);
      })
      .catch(() => {
        root.innerHTML = '<p class="text-offset">Failed to load designs.</p>';
      });
  })();
</script>

