---
import { Icon } from "astro-icon/components";

interface Props {
  value: string;
  title?: string;
}

const { value, title = "Copy" } = Astro.props;
---

<button
  type="button"
  class="copy-value__btn inline-flex size-5 shrink-0 items-center justify-center rounded text-offset transition-colors hover:text-default focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-1"
  data-copy-value={value}
  aria-label={title}
  title={title}
>
  <span class="copy-value__icon-copy" aria-hidden="true">
    <Icon name="mdi:content-copy" class="size-3.5" aria-hidden="true" />
  </span>
  <span class="copy-value__icon-check" aria-hidden="true">
    <Icon name="mdi:check" class="size-3.5" aria-hidden="true" />
  </span>
</button>

<style is:global>
  .copy-value__icon-check {
    display: none;
  }
  .copy-value__btn--copied .copy-value__icon-copy {
    display: none;
  }
  .copy-value__btn--copied .copy-value__icon-check {
    display: block;
  }
</style>

<script>
  (function () {
    const CLS_BTN = "copy-value__btn";
    const COPIED_CLASS = "copy-value__btn--copied";
    const COPIED_DURATION_MS = 1500;

    document.body.addEventListener("click", (e) => {
      const target = e.target instanceof Element ? e.target : null;
      const btn = target?.closest(`.${CLS_BTN}`) ?? null;
      if (!btn) return;
      const value = btn.getAttribute("data-copy-value");
      if (value == null) return;
      const prevLabel = btn.getAttribute("aria-label") || "Copy";
      navigator.clipboard.writeText(value).then(() => {
        btn.classList.add(COPIED_CLASS);
        btn.setAttribute("aria-label", "Copied!");
        setTimeout(() => {
          btn.classList.remove(COPIED_CLASS);
          btn.setAttribute("aria-label", prevLabel);
        }, COPIED_DURATION_MS);
      }).catch(() => {});
    });
  })();
</script>
