---
import { Icon } from "astro-icon/components";

interface Props {
  value?: string;
  sourceSelector?: string;
  action?: string;
  disabled?: boolean;
  buttonClass?: string;
  showLabel?: boolean;
  label?: string;
  title?: string;
}

const {
  value = "",
  sourceSelector,
  action,
  disabled = false,
  buttonClass = "",
  showLabel = false,
  label = "Copy",
  title = "Copy",
} = Astro.props as Props;
---

<button
  type="button"
  class={`copy-value__btn inline-flex size-5 shrink-0 items-center justify-center rounded text-offset transition-colors hover:text-default focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-1 ${buttonClass}`.trim()}
  data-copy-value={value}
  data-copy-source={sourceSelector}
  data-action={action}
  aria-label={title}
  title={title}
  disabled={disabled}
>
  <span class="copy-value__icon-copy" aria-hidden="true">
    <Icon name="mdi:content-copy" class="size-3.5" aria-hidden="true" />
  </span>
  <span class="copy-value__icon-check" aria-hidden="true">
    <Icon name="mdi:check" class="size-3.5" aria-hidden="true" />
  </span>
  {
    showLabel ? (
      <span class="copy-value__label ml-1.5">{label}</span>
    ) : null
  }
</button>

<style is:global>
  .copy-value__icon-check {
    display: none;
  }
  .copy-value__btn--copied .copy-value__icon-copy {
    display: none;
  }
  .copy-value__btn--copied .copy-value__icon-check {
    display: block;
  }
</style>
