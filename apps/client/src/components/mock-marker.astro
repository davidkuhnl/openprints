---
// Absolutely positioned stamp-style label for mock data. Parent must have position: relative.
interface Props {
  /** Offset from top in pixels (default 0). */
  top?: number;
  /** Offset from right in pixels (default 0). */
  right?: number;
  /** Rotation in degrees (default 45). */
  rotation?: number;
}

const { top = 0, right = 0, rotation = 45 }: Props = Astro.props;
const style = `top: ${top}px; right: ${right}px; transform: translateY(-50%) translateX(50%) scale(0.8) rotate(${rotation}deg);`;
---

<div
  class="pointer-events-none absolute origin-top-right rounded border border-red-400/60 bg-red-500/10 px-3 py-1 text-[8px] font-semibold uppercase tracking-wider text-red-500/70 shadow-sm"
  style={style}
  aria-hidden="true"
>
  MOCK DATA
</div>
