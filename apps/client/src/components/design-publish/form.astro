---
import { Icon } from "astro-icon/components";
import NostrSignerDetected from "~/components/nostr-signer-detected.astro";
import DesignPublishStepPanel from "~/components/design-publish/step-panel.astro";
import EventJsonPanel from "~/components/event-json-panel.astro";
import DesignPublishInfoPanel from "~/components/design-publish/info-panel.astro";
import type { DesignPublishFormMode, Inputs } from "~/lib/design-publish/form-types";

const apiBaseUrl = import.meta.env.PUBLIC_OPENPRINTS_API_URL ?? "";
const apiBase = apiBaseUrl ? apiBaseUrl.replace(/\/$/, "") : "";

interface Props {
  mode?: DesignPublishFormMode;
  lockedDesignId?: string | null;
  initialValues?: Partial<Inputs> | null;
  signButtonLabel?: string;
  publishButtonLabel?: string;
}

const {
  mode = "create",
  lockedDesignId = null,
  initialValues = null,
  signButtonLabel = "Sign",
  publishButtonLabel = "Publish",
} = Astro.props as Props;

const serializedInitialValues = initialValues ? JSON.stringify(initialValues) : "";
---

<section
  class="space-y-3 px-4 pb-4 pt-3 sm:px-5 sm:pb-5 sm:pt-4"
  data-design-publish-form
  data-api-base={apiBase}
  data-form-mode={mode}
  data-locked-design-id={lockedDesignId ?? ""}
  data-initial-values={serializedInitialValues}
  aria-live="polite"
>

  <form class="space-y-0" data-publish-form novalidate>
    <DesignPublishStepPanel
      stepId="signer"
      stepNumber={1}
      title="Signer"
      summary="Signer"
      showBack={false}
      panelClass="bg-transparent"
    >
      <Fragment slot="value">
        <span
          class="hidden items-center gap-1.5 whitespace-nowrap rounded-md border border-emerald-400/20 bg-emerald-400/6 px-2.5 py-1 text-[11px] text-offset/90 sm:inline-flex"
          data-step-signer-pill
        >
          <span class="hidden size-1.5 shrink-0 rounded-full bg-emerald-400" data-step-signer-dot aria-hidden="true" />
          <span data-step-signer-pill-text>-</span>
        </span>
      </Fragment>
      <div class="relative">
        <NostrSignerDetected />
      </div>
    </DesignPublishStepPanel>

<DesignPublishStepPanel stepId="file" stepNumber={2} title="Design File" summary="Add a file URL and optional digest">
  <div class="space-y-4">
    <div class="space-y-1">
      <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-offset/80">
        File source
      </p>
      <p class="text-[11px] leading-relaxed text-offset/75">
        Provide the HTTPS location of the design file. You can optionally add a SHA-256 digest for integrity verification.
      </p>
    </div>

    <div class="space-y-1.5">
      <label for="design-url" class="text-xs font-medium text-default">
        File URL <span class="text-red-400">*</span>
      </label>
      <input
        id="design-url"
        name="url"
        type="url"
        required
        autocomplete="off"
        placeholder="https://example.com/designs/phone-stand.stl"
        class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
        data-field="url"
      />
      <p class="text-[11px] text-offset/70">
        Paste a direct <span class="font-mono">https://</span> link to the hosted design file.
      </p>
    </div>

    <div class="space-y-1.5">
      <label for="design-sha256" class="text-xs font-medium text-default">
        SHA-256 <span class="text-offset/70">(optional)</span>
      </label>
      <input
        id="design-sha256"
        name="sha256"
        type="text"
        autocomplete="off"
        placeholder="64-char lowercase hex digest"
        class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs font-mono text-default placeholder:font-sans placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
        data-field="sha256"
      />
      <p class="text-[11px] text-offset/70">
        Used to verify that the hosted file hasn’t changed. Recommended if you control the file host.
      </p>
    </div>

    <div class="space-y-2 border-t border-default/40 pt-3">
      <DesignPublishInfoPanel
        icon="mdi:tray-arrow-up"
        title="Built-in upload is coming"
        description="For now, host your design file somewhere public and paste the HTTPS URL above."
        panelClass="border-default/30 bg-default/[0.03]"
      />

      <DesignPublishInfoPanel
        icon="mdi:tray-arrow-down"
        title="Platform import is planned"
        description="You’ll later be able to import designs directly from popular 3D model platforms."
      />
    </div>
  </div>
</DesignPublishStepPanel>

    <DesignPublishStepPanel stepId="name" stepNumber={3} title="Design Name" summary="Name your design">
      <div class="space-y-1.5">
        <label for="design-name" class="text-xs font-medium text-default">Design Name <span class="text-red-400">*</span></label>
        <input id="design-name" name="name" type="text" maxlength="140" required autocomplete="off" placeholder="Phone Stand" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="name" />
      </div>
    </DesignPublishStepPanel>


    <DesignPublishStepPanel stepId="format" stepNumber={4} title="Format and MIME type" summary="Choose the primary format">
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="space-y-1.5">
          <label for="design-format" class="text-xs font-medium text-default">Format <span class="text-red-400">*</span></label>
          <select id="design-format" name="format" required class="w-full rounded-md border border-default bg-offset/10 px-3 py-2 text-xs text-default focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="format">
            <option value="">Select a format...</option>
            <option value="stl">stl</option>
            <option value="3mf">3mf</option>
            <option value="step">step</option>
            <option value="obj">obj</option>
            <option value="gcode">gcode</option>
          </select>
        </div>
        <div class="space-y-1.5">
          <div class="flex items-center justify-between gap-2">
            <label for="design-mime" class="text-xs font-medium text-default">
              MIME type <span class="text-offset/70">(optional)</span>
            </label>
            <button
              type="button"
              class="hidden mr-6 text-xs font-medium text-offset/70 underline-offset-2 hover:text-offset/90 hover:underline focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-emerald-300/60"
              data-action="infer-mime"
            >
              Infer from format
            </button>
          </div>
          <input id="design-mime" name="m" type="text" autocomplete="off" placeholder="model/stl" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="mime" />
        </div>
      </div>
    </DesignPublishStepPanel>


    <DesignPublishStepPanel stepId="description" stepNumber={5} title="Description" summary="Optional description">
      <div class="space-y-1.5">
        <label for="design-description" class="text-xs font-medium text-default">Description <span class="text-offset/70">(optional)</span></label>
        <textarea id="design-description" name="description" rows="4" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" placeholder="Short description. Markdown allowed." data-field="description"></textarea>
      </div>
    </DesignPublishStepPanel>

    <DesignPublishStepPanel stepId="design-images" stepNumber={6} title="Images" summary="Optional preview URLs">
      <div class="space-y-3">
        <div class="space-y-1.5">
          <label for="design-preview" class="text-xs font-medium text-default">Preview image URLs (one per line)</label>
          <textarea id="design-preview" name="preview" rows="3" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" placeholder="https://.../preview.png" data-field="preview"></textarea>
          <p class="text-[11px] text-offset/75">
            Paste one <span class="font-mono">https://</span> URL per line. We will try to render each image below.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-4" data-preview-render-list>
          <p class="col-span-full rounded-md border border-dashed border-default/40 bg-default/[0.02] px-3 py-2 text-[11px] text-offset/75" data-preview-render-empty>
            No preview images yet.
          </p>
        </div>
      </div>
    </DesignPublishStepPanel>

    <DesignPublishStepPanel stepId="lightning-payments" stepNumber={7} title="Lightning Address" summary="Optional LNURL">
      <div class="space-y-3">
        <div class="space-y-1.5">
          <label for="design-lnurl" class="text-xs font-medium text-default">LNURL pay address <span class="text-offset/70">(optional)</span></label>
          <input id="design-lnurl" name="lnurl" type="text" autocomplete="off" placeholder="lnurlp://creator.example.com/pay" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="lnurl" />
          <input type="hidden" name="d" data-field="d" />
          <input type="hidden" name="previousVersionEventId" data-field="previousVersionEventId" />
        </div>
        <DesignPublishInfoPanel
          icon="mdi:lightning-bolt"
          title="Paid models are coming soon"
          description="Adding a Lightning address already lets people send voluntary contributions to support your work."
        />
      </div>
    </DesignPublishStepPanel>

    <DesignPublishStepPanel stepId="additional-data" stepNumber={8} title="Additional Data" summary="Optional metadata" showNext={false}>
      <div class="space-y-3">
        <div class="space-y-1.5">
          <label for="design-license" class="text-xs font-medium text-default">License <span class="text-offset/70">(optional)</span></label>
          <input id="design-license" name="license" type="text" autocomplete="off" placeholder="CC-BY-4.0" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" data-field="license" />
        </div>
        <div class="space-y-1.5">
          <label for="design-category" class="text-xs font-medium text-default">Categories (one per line)</label>
          <textarea id="design-category" name="category" rows="3" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" placeholder="holder" data-field="category"></textarea>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <div class="space-y-1.5">
            <label for="design-material" class="text-xs font-medium text-default">Materials tested (one per line)</label>
            <textarea id="design-material" name="material" rows="3" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" placeholder="PLA" data-field="material"></textarea>
          </div>
          <div class="space-y-1.5">
            <label for="design-printer" class="text-xs font-medium text-default">Printers tested (one per line)</label>
            <textarea id="design-printer" name="printer" rows="3" class="w-full rounded-md border border-default bg-white/0 px-3 py-2 text-xs text-default placeholder:text-offset/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60" placeholder="Prusa MK4" data-field="printer"></textarea>
          </div>
        </div>
      </div>
    </DesignPublishStepPanel>

    <div class="mt-3 space-y-3 px-3 pt-3">
<div class="flex flex-wrap items-center justify-between gap-3 border-t border-default/40 pt-4">

  <!-- Primary actions -->
  <div class="flex items-center gap-2">

    <button
      type="button"
      class="inline-flex items-center gap-2 rounded-md border border-emerald-400/40 bg-emerald-400/12 px-3.5 py-2 text-xs font-semibold text-default transition hover:bg-emerald-400/22 disabled:cursor-not-allowed disabled:opacity-45 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
      data-action="sign"
    >
      <Icon name="mdi:pen" class="size-4" />
      {signButtonLabel}
    </button>

    <button
      type="button"
      class="inline-flex items-center gap-2 rounded-md border border-sky-400/40 bg-sky-400/12 px-3.5 py-2 text-xs font-semibold text-default transition hover:bg-sky-400/22 disabled:cursor-not-allowed disabled:opacity-45 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-300/60"
      data-action="publish"
      disabled
    >
      <Icon name="mdi:send" class="size-4" />
      {publishButtonLabel}
    </button>

  </div>


  <!-- Secondary actions -->
  <div class="flex items-center gap-2">

    <button
      type="button"
      class="inline-flex items-center gap-1.5 rounded-md border border-default/70 bg-default/[0.03] px-2.5 py-1.5 text-[11px] font-medium text-offset transition hover:bg-default/20 hover:text-default focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
      data-action="reset"
    >
      <Icon name="mdi:refresh" class="size-3.5" />
      Reset Form
    </button>

    <button
      type="button"
      class="inline-flex items-center gap-1.5 rounded-md border border-default/70 bg-default/[0.03] px-2.5 py-1.5 text-[11px] font-medium text-offset transition hover:bg-default/20 hover:text-default focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
      data-action="toggle-hacker"
      aria-expanded="false"
    >
      <Icon name="mdi:code-tags" class="size-3.5" />
      <span data-hacker-toggle-label>Show Nostr data</span>
    </button>

  </div>

</div>
      <p class="text-xs text-offset" data-sign-status>Waiting for signer pubkey...</p>
      <div class="hidden space-y-3" data-hacker-field>
        <EventJsonPanel
          sectionTitle="Unsigned event"
          sectionDescription="Preview of the event before signing."
          copyAction="copy-unsigned"
          textareaId="unsigned-event"
          outputName="unsigned"
          headerLabel="JSON preview"
          headerValue="kind 33301"
          headerValueClass="text-offset/55"
        />
        <EventJsonPanel
          sectionTitle="Signed event"
          sectionDescription="Final event payload ready to publish."
          copyAction="copy-signed"
          textareaId="signed-event"
          outputName="signed"
          headerLabel="JSON payload"
          headerValue="signed"
          headerValueClass="text-emerald-300/80"
        />
        <p class="text-[11px] text-offset" data-validation-summary>Waiting for signer and valid inputs.</p>
      </div>
    </div>
  </form>
</section>

<script>
  import { initDesignPublishForm } from "~/lib/design-publish/form-controller";

  initDesignPublishForm();
</script>

<style>
  .signer-status-dot--blinking {
    animation: signerStatusBlink 1.2s infinite ease-in-out;
  }

  @keyframes signerStatusBlink {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 1;
    }
  }
</style>