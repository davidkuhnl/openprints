---
import { Icon } from "astro-icon/components";

type Props = {
  stepId: string;
  stepNumber: number;
  title: string;
  summary?: string;
  showBack?: boolean;
  showNext?: boolean;
  panelClass?: string;
  bodyClass?: string;
  nextLabel?: string;
};

const {
  stepId,
  stepNumber: _stepNumber,
  title,
  summary = "",
  showBack = true,
  showNext = true,
  panelClass = "",
  bodyClass = "",
  nextLabel = "Next",
} = Astro.props as Props;
---

<section
  class={`overflow-hidden bg-transparent ${panelClass}`.trim()}
  data-step-panel={stepId}
  data-validation-state="empty"
  data-view-state="collapsed"
>
  <button
    type="button"
    class="inline-flex items-center justify-center rounded-md px-1.5 py-1 text-offset/75 transition hover:bg-default/10 hover:text-default focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
    data-step-caret={stepId}
    aria-label={`Toggle ${title}`}
  >
    <Icon
      name="mdi:chevron-down"
      class="size-4 shrink-0 transition-transform duration-200"
      data-step-caret-icon={stepId}
    />
  </button>

  <button
    type="button"
    class="flex w-full items-center gap-3 px-4 py-3.5 pr-11 text-left transition duration-150 hover:bg-default/8 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
    data-step-toggle={stepId}
  >
    <div class="flex min-w-0 items-center gap-3">
      <span
        class="hidden size-5 shrink-0 items-center justify-center rounded-full border border-emerald-400/35 bg-emerald-400/12 text-emerald-300 transition-colors duration-200"
        data-step-check={stepId}
        aria-hidden="true"
      >
        <Icon name="mdi:check" class="size-3.5" />
      </span>

      <p
        class="truncate text-[13px] font-semibold tracking-tight text-default/92 transition-colors duration-200"
        data-step-title
      >
        {title}
      </p>
    </div>

    <div class="ml-auto min-w-0 max-w-[48%] text-right">
      <slot name="value">
        <p
          class="truncate text-[11px] font-medium text-offset/68 transition-colors duration-200"
          data-step-summary={stepId}
        >
          {summary}
        </p>
      </slot>
    </div>
  </button>

  <div
    class={`hidden border-t border-default/40 px-4 pb-4 pt-3 ${bodyClass}`.trim()}
    data-step-body={stepId}
  >
    <div class="rounded-md bg-default/[0.02] px-1 py-0.5">
      <slot />
    </div>

    <div
      class="mt-5 flex items-center justify-end gap-2 border-t border-default/35 pt-3"
      data-step-actions={stepId}
    >
      {
        showBack ? (
          <button
            type="button"
            class="inline-flex items-center gap-1.5 rounded-md border border-default/65 bg-transparent px-3 py-1.5 text-xs font-medium text-offset/85 transition duration-150 hover:border-default/90 hover:bg-default/10 hover:text-default focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
            data-step-back={stepId}
          >
            <Icon name="mdi:arrow-left" class="size-3.5" />
            Back
          </button>
        ) : null
      }

      {
        showNext ? (
          <button
            type="button"
            class="inline-flex items-center gap-1.5 rounded-md border border-emerald-400/30 bg-emerald-400/10 px-3 py-1.5 text-xs font-semibold text-default transition duration-150 hover:border-emerald-400/40 hover:bg-emerald-400/16 disabled:cursor-not-allowed disabled:opacity-45 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
            data-step-next={stepId}
          >
            {nextLabel}
            <Icon name="mdi:arrow-right" class="size-3.5" />
          </button>
        ) : null
      }
    </div>
  </div>
</section>

<style>
  [data-step-panel] {
    position: relative;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
    border-left: 2px solid transparent;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 18%, transparent);
  }

  [data-step-panel]:last-child {
    border-bottom-color: transparent;
  }

  [data-step-caret] {
    position: absolute;
    right: 0.5rem;
    top: 0.5rem;
    z-index: 20;
    border: 0;
    background: transparent;
  }

  [data-step-panel][data-view-state="expanded"] [data-step-caret-icon] {
    transform: rotate(180deg);
    color: color-mix(in srgb, var(--color-text) 95%, transparent);
  }

  [data-step-panel][data-view-state="expanded"] {
    background: color-mix(in srgb, var(--color-text) 2%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-border) 12%, transparent);
  }

  [data-step-panel][data-view-state="expanded"] [data-step-title] {
    color: var(--color-text);
  }

  [data-step-panel][data-view-state="expanded"] [data-step-summary] {
    color: color-mix(in srgb, var(--color-text-offset) 72%, transparent);
  }

  [data-step-panel][data-view-state="collapsed"][data-validation-state="valid"] [data-step-summary] {
    color: color-mix(in srgb, var(--color-text-offset) 66%, transparent);
  }

  [data-step-panel][data-view-state="collapsed"][data-validation-state="empty"] [data-step-summary] {
    color: color-mix(in srgb, var(--color-text-offset) 58%, transparent);
  }

  [data-step-panel][data-view-state="collapsed"][data-validation-state="invalid"] [data-step-summary] {
    color: color-mix(in srgb, var(--color-text-offset) 76%, transparent);
  }

  [data-step-panel][data-validation-state="empty"] {
    border-left-color: rgb(148 163 184 / 0.28);
  }

  [data-step-panel][data-validation-state="valid"] {
    border-left-color: rgb(16 185 129 / 0.72);
  }

  [data-step-panel][data-form-mode="edit"][data-edit-state="changed"] [data-step-title]::after {
    content: " · edited";
    color: rgb(125 211 252 / 0.95);
    font-weight: 600;
  }

  [data-step-panel][data-form-mode="edit"][data-edit-state="unchanged"] [data-step-title]::after {
    content: " · unchanged";
    color: color-mix(in srgb, var(--color-text-offset) 30%, transparent);
    font-weight: 400;
  }

  [data-step-panel][data-validation-state="invalid"] {
    border-left-color: rgb(251 191 36 / 0.28);
  }

  [data-step-panel][data-validation-state="valid"] [data-step-check] {
    display: inline-flex;
  }

  [data-step-panel][data-validation-state="valid"] [data-step-title] {
    color: color-mix(in srgb, var(--color-text) 90%, transparent);
  }

  [data-step-panel][data-validation-state="empty"] [data-step-title] {
    color: color-mix(in srgb, var(--color-text) 90%, transparent);
  }

  [data-step-panel][data-validation-state="invalid"] [data-step-title] {
    color: color-mix(in srgb, var(--color-text) 95%, transparent);
  }

  [data-step-panel][data-validation-state="valid"][data-view-state="collapsed"] [data-step-toggle]:hover {
    background: rgb(52 211 153 / 0.05);
  }

  [data-step-panel][data-validation-state="empty"][data-view-state="collapsed"] [data-step-toggle]:hover {
    background: color-mix(in srgb, var(--color-text) 2%, transparent);
  }

  [data-step-panel][data-validation-state="invalid"][data-view-state="collapsed"] [data-step-toggle]:hover {
    background: rgb(251 191 36 / 0.05);
  }
</style>
