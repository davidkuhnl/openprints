---
import IdentityDetailCardValid from "~/components/identity-detail-card-valid.astro";
import IdentityDetailCardError from "~/components/identity-detail-card-error.astro";
import type { IdentityDetailModel } from "~/lib/identities";

interface Props {
  identity: IdentityDetailModel | null;
  errorTitle?: string | null;
  errorMessage?: string | null;
  identityId: string;
  totalDesignsForIdentity?: number | null;
  totalVersionsForIdentity?: number | null;
  designsPreviewLimit?: number;
  showPublishActions?: boolean;
  publishHref?: string;
}

const {
  identity,
  errorTitle = null,
  errorMessage = null,
  identityId,
  totalDesignsForIdentity = null,
  totalVersionsForIdentity = null,
  designsPreviewLimit = 6,
  showPublishActions = false,
  publishHref = "/app/designs/new",
} = Astro.props as Props;
---

{
  errorMessage ? (
    <IdentityDetailCardError errorTitle={errorTitle} errorMessage={errorMessage} />
  ) : !identity ? (
    <article class="mx-auto flex max-w-5xl flex-col gap-2.5 rounded-xl border border-default bg-offset/30 p-4 sm:p-5">
      <h1 class="text-lg font-semibold tracking-tight">Loading identity...</h1>
      <p class="text-xs text-offset">Fetching identity details.</p>
    </article>
  ) : (
    <IdentityDetailCardValid
      identity={identity}
      identityId={identityId}
      totalDesignsForIdentity={totalDesignsForIdentity}
      totalVersionsForIdentity={totalVersionsForIdentity}
      designsPreviewLimit={designsPreviewLimit}
      showPublishActions={showPublishActions}
      publishHref={publishHref}
    />
  )
}
